<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Cron: Sync Learning Progress -->
        <record id="ir_cron_sync_learning_progress" model="ir.cron">
            <field name="name">HR: Sync Learning Progress</field>
            <field name="model_id" ref="impc_hr_skills_sync.model_hr_learning_progress"/>
            <field name="state">code</field>
            <field name="code">model._sync_learning_progress_from_elearning()</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">5</field>
            <field name="interval_type">minutes</field>
            <field name="active" eval="True"/>
        </record>

        <!-- Cron: Send At-Risk Alerts -->
        <record id="ir_cron_send_at_risk_alerts" model="ir.cron">
            <field name="name">HR: Send At-Risk Alerts</field>
            <field name="model_id" ref="impc_hr_skills_sync.model_hr_learning_progress"/>
            <field name="state">code</field>
            <field name="code">model._send_at_risk_alerts()</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>
