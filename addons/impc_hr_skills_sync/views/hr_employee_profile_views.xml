<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- Employee Learning Profile                                    -->
    <!-- ============================================================ -->

    <template id="hr_employee_profile" name="Employee Learning Profile">
        <t t-call="website.layout">
            <t t-set="title" t-out="'{} - Learning Profile'.format(employee.name)"/>

            <div class="impc-dashboard py-4">
                <div class="container">
                    <!-- Header -->
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <div>
                            <nav aria-label="breadcrumb">
                                <ol class="breadcrumb mb-1">
                                    <li class="breadcrumb-item"><a href="/hr/dashboard">HR Dashboard</a></li>
                                    <li class="breadcrumb-item"><a href="/hr/employees">Employees</a></li>
                                    <li class="breadcrumb-item active" t-out="employee.name"/>
                                </ol>
                            </nav>
                            <h2 class="fw-bold mb-0" t-out="employee.name"/>
                            <p class="text-muted mb-0">
                                <t t-if="employee.department_id">
                                    <i class="fa fa-building me-1"></i>
                                    <span t-out="employee.department_id.name"/>
                                </t>
                                <t t-if="employee.job_id">
                                    <span class="mx-2">•</span>
                                    <span t-out="employee.job_id.name"/>
                                </t>
                            </p>
                        </div>
                        <div>
                            <t t-if="is_own_profile">
                                <span class="badge bg-primary">Your Profile</span>
                            </t>
                        </div>
                    </div>

                    <!-- Stats Cards -->
                    <div class="row g-3 mb-4">
                        <div class="col-md-2">
                            <div class="card border-0 shadow-sm rounded-3 h-100">
                                <div class="card-body text-center p-3">
                                    <h4 class="fw-bold mb-0" t-out="total_courses"/>
                                    <small class="text-muted">Courses</small>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="card border-0 shadow-sm rounded-3 h-100">
                                <div class="card-body text-center p-3">
                                    <h4 class="fw-bold text-info mb-0" t-out="in_progress_count"/>
                                    <small class="text-muted">In Progress</small>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="card border-0 shadow-sm rounded-3 h-100">
                                <div class="card-body text-center p-3">
                                    <h4 class="fw-bold text-success mb-0" t-out="completed_count"/>
                                    <small class="text-muted">Completed</small>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="card border-0 shadow-sm rounded-3 h-100">
                                <div class="card-body text-center p-3">
                                    <h4 class="fw-bold text-warning mb-0" t-out="at_risk_count"/>
                                    <small class="text-muted">At Risk</small>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="card border-0 shadow-sm rounded-3 h-100">
                                <div class="card-body text-center p-3">
                                    <h4 class="fw-bold text-primary mb-0" t-out="total_skills"/>
                                    <small class="text-muted">Skills</small>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="card border-0 shadow-sm rounded-3 h-100">
                                <div class="card-body text-center p-3">
                                    <h4 class="fw-bold mb-0" t-out="total_certificates"/>
                                    <small class="text-muted">Certificates</small>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="row g-4">
                        <!-- Main Content -->
                        <div class="col-lg-8">
                            <!-- Learning Progress -->
                            <div class="card border-0 shadow-sm rounded-3 mb-4">
                                <div class="card-header bg-white border-0 pt-3 px-4">
                                    <h5 class="fw-bold mb-0">
                                        <i class="fa fa-book text-primary me-2"></i>Learning Progress
                                    </h5>
                                </div>
                                <div class="card-body px-4 pb-4">
                                    <t t-if="progress_records">
                                        <div class="table-responsive">
                                            <table class="table table-hover align-middle mb-0">
                                                <thead class="table-light">
                                                    <tr>
                                                        <th>Course</th>
                                                        <th class="text-center">Progress</th>
                                                        <th class="text-center">Status</th>
                                                        <th class="text-center">Mode</th>
                                                        <th class="text-center">Last Accessed</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    <t t-foreach="progress_records[:10]" t-as="rec">
                                                        <tr>
                                                            <td>
                                                                <span class="fw-semibold" t-out="rec.course_name"/>
                                                            </td>
                                                            <td class="text-center">
                                                                <div class="d-flex align-items-center justify-content-center">
                                                                    <div class="progress me-2" style="width: 60px; height: 8px;">
                                                                        <div class="progress-bar" 
                                                                             t-attf-class="bg-#{rec.status == 'completed' and 'success' or rec.status == 'at_risk' and 'warning' or 'primary'}"
                                                                             t-attf-style="width: #{rec.completion_percentage}%"/>
                                                                    </div>
                                                                    <small t-out="'{}%'.format(rec.completion_percentage)"/>
                                                                </div>
                                                            </td>
                                                            <td class="text-center">
                                                                <span t-attf-class="badge bg-#{rec.status == 'completed' and 'success' or rec.status == 'at_risk' and 'warning' or 'info'} bg-opacity-10 text-#{rec.status == 'completed' and 'success' or rec.status == 'at_risk' and 'warning' or 'info'}">
                                                                    <span t-out="rec.status.replace('_', ' ').title()"/>
                                                                </span>
                                                            </td>
                                                            <td class="text-center">
                                                                <small t-out="rec.learning_mode.title() if rec.learning_mode else 'Online'"/>
                                                            </td>
                                                            <td class="text-center">
                                                                <small t-out="rec.last_accessed_date" t-options="{'widget': 'date'}"/>
                                                            </td>
                                                        </tr>
                                                    </t>
                                                </tbody>
                                            </table>
                                        </div>
                                    </t>
                                    <t t-if="not progress_records">
                                        <div class="text-center py-4">
                                            <i class="fa fa-book fa-2x text-muted mb-2"></i>
                                            <p class="text-muted mb-0">No learning progress yet</p>
                                        </div>
                                    </t>
                                </div>
                            </div>

                            <!-- Skills -->
                            <div class="card border-0 shadow-sm rounded-3 mb-4">
                                <div class="card-header bg-white border-0 pt-3 px-4">
                                    <h5 class="fw-bold mb-0">
                                        <i class="fa fa-star text-warning me-2"></i>Skills Acquired
                                    </h5>
                                </div>
                                <div class="card-body px-4 pb-4">
                                    <t t-if="skills">
                                        <div class="row">
                                            <t t-foreach="skills" t-as="skill">
                                                <div class="col-md-6 mb-3">
                                                    <div class="border rounded p-2">
                                                        <div class="d-flex justify-content-between align-items-center">
                                                            <div>
                                                                <small class="fw-bold d-block" t-out="skill.skill_id.name"/>
                                                                <small class="text-muted" t-out="skill.skill_type_id.name"/>
                                                            </div>
                                                            <span class="badge bg-warning bg-opacity-10 text-warning" t-out="skill.skill_level_id.name"/>
                                                        </div>
                                                    </div>
                                                </div>
                                            </t>
                                        </div>
                                    </t>
                                    <t t-if="not skills">
                                        <div class="text-center py-3">
                                            <i class="fa fa-star fa-2x text-muted mb-2"></i>
                                            <p class="text-muted mb-0">No skills recorded yet</p>
                                        </div>
                                    </t>
                                </div>
                            </div>

                            <!-- Certificates -->
                            <div class="card border-0 shadow-sm rounded-3">
                                <div class="card-header bg-white border-0 pt-3 px-4">
                                    <h5 class="fw-bold mb-0">
                                        <i class="fa fa-certificate text-success me-2"></i>Certificates Earned
                                    </h5>
                                </div>
                                <div class="card-body px-4 pb-4">
                                    <t t-if="certificates">
                                        <t t-foreach="certificates" t-as="cert">
                                            <div class="d-flex align-items-center py-2 border-bottom">
                                                <div class="bg-success bg-opacity-10 rounded p-2 me-3">
                                                    <i class="fa fa-certificate text-success"></i>
                                                </div>
                                                <div class="flex-grow-1">
                                                    <small class="fw-bold d-block" t-out="cert.channel_id.name"/>
                                                    <small class="text-muted" t-out="cert.name"/>
                                                </div>
                                                <small class="text-muted" t-out="cert.issued_date"/>
                                            </div>
                                        </t>
                                    </t>
                                    <t t-if="not certificates">
                                        <div class="text-center py-3">
                                            <i class="fa fa-certificate fa-2x text-muted mb-2"></i>
                                            <p class="text-muted mb-0">No certificates earned yet</p>
                                        </div>
                                    </t>
                                </div>
                            </div>
                        </div>

                        <!-- Sidebar -->
                        <div class="col-lg-4">
                            <!-- Add Note Form -->
                            <div class="card border-0 shadow-sm rounded-3 mb-4">
                                <div class="card-body p-3">
                                    <h6 class="fw-bold mb-3">
                                        <i class="fa fa-plus text-primary me-2"></i>Add Learning Note
                                    </h6>
                                    <form t-attf-action="/hr/employee/#{employee.id}/note/add" method="POST">
                                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                        <div class="mb-3">
                                            <textarea name="note_text" class="form-control" rows="3" 
                                                      placeholder="Add a note about this employee's learning progress..."></textarea>
                                        </div>
                                        <button type="submit" class="btn btn-primary btn-sm w-100">
                                            <i class="fa fa-save me-1"></i>Save Note
                                        </button>
                                    </form>
                                </div>
                            </div>

                            <!-- Skill History -->
                            <div class="card border-0 shadow-sm rounded-3 mb-4">
                                <div class="card-body p-3">
                                    <h6 class="fw-bold mb-3">
                                        <i class="fa fa-history text-info me-2"></i>Skill History
                                    </h6>
                                    <t t-if="skill_logs">
                                        <t t-foreach="skill_logs" t-as="log">
                                            <div class="border-bottom pb-2 mb-2">
                                                <div class="d-flex justify-content-between">
                                                    <small class="fw-bold" t-out="log.skill_id.name"/>
                                                    <small class="text-muted" t-out="log.change_date"/>
                                                </div>
                                                <small class="text-muted">
                                                    <span t-out="log.skill_level_before_id.name if log.skill_level_before_id else 'None'"/>
                                                    <i class="fa fa-arrow-right mx-1"></i>
                                                    <span t-out="log.skill_level_after_id.name"/>
                                                </small>
                                            </div>
                                        </t>
                                    </t>
                                    <t t-if="not skill_logs">
                                        <p class="text-muted small mb-0">No skill updates yet</p>
                                    </t>
                                </div>
                            </div>

                            <!-- Learning Notes -->
                            <div class="card border-0 shadow-sm rounded-3">
                                <div class="card-body p-3">
                                    <h6 class="fw-bold mb-3">
                                        <i class="fa fa-sticky-note text-secondary me-2"></i>Learning Notes
                                    </h6>
                                    <t t-if="notes">
                                        <t t-foreach="notes" t-as="note">
                                            <div class="border-bottom pb-2 mb-2">
                                                <small t-out="note.note_text"/>
                                                <div class="d-flex justify-content-between mt-1">
                                                    <small class="text-muted" t-out="note.created_by.name"/>
                                                    <small class="text-muted" t-out="note.note_date"/>
                                                </div>
                                            </div>
                                        </t>
                                    </t>
                                    <t t-if="not notes">
                                        <p class="text-muted small mb-0">No notes yet</p>
                                    </t>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <!-- ============================================================ -->
    <!-- Employee List                                                -->
    <!-- ============================================================ -->

    <template id="hr_employee_list" name="HR Employee List">
        <t t-call="website.layout">
            <t t-set="title">Employees - HR Dashboard</t>

            <div class="impc-dashboard py-4">
                <div class="container">
                    <!-- Header -->
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <div>
                            <h2 class="fw-bold mb-1">
                                <i class="fa fa-users text-primary me-2"></i>Employees
                            </h2>
                            <p class="text-muted mb-0" t-out="'{} employees with learning data'.format(total_employees)"/>
                        </div>
                        <a href="/hr/dashboard" class="btn btn-outline-primary">
                            <i class="fa fa-arrow-left me-1"></i>Back to Dashboard
                        </a>
                    </div>

                    <!-- Filters -->
                    <div class="card border-0 shadow-sm rounded-3 mb-4">
                        <div class="card-body p-3">
                            <form method="get" class="row g-3 align-items-end">
                                <div class="col-md-4">
                                    <label class="form-label small">Search</label>
                                    <input type="text" name="search" class="form-control" 
                                           t-att-value="search" placeholder="Name or email..."/>
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label small">Department</label>
                                    <select name="department_id" class="form-select">
                                        <option value="">All Departments</option>
                                        <t t-foreach="departments" t-as="dept">
                                            <option t-att-value="dept.id" t-att-selected="selected_department == dept.id">
                                                <span t-out="dept.name"/>
                                            </option>
                                        </t>
                                    </select>
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label small">Status</label>
                                    <select name="status" class="form-select">
                                        <option value="all">All Status</option>
                                        <option value="in_progress" t-att-selected="selected_status == 'in_progress'">In Progress</option>
                                        <option value="completed" t-att-selected="selected_status == 'completed'">Completed</option>
                                        <option value="at_risk" t-att-selected="selected_status == 'at_risk'">At Risk</option>
                                    </select>
                                </div>
                                <div class="col-md-2">
                                    <button type="submit" class="btn btn-primary w-100">Filter</button>
                                </div>
                            </form>
                        </div>
                    </div>

                    <!-- Employee List -->
                    <div class="card border-0 shadow-sm rounded-3">
                        <div class="card-body px-4 pb-4">
                            <t t-if="employee_data">
                                <div class="table-responsive">
                                    <table class="table table-hover align-middle">
                                        <thead class="table-light">
                                            <tr>
                                                <th>Employee</th>
                                                <th>Department</th>
                                                <th class="text-center">Courses</th>
                                                <th class="text-center">In Progress</th>
                                                <th class="text-center">Completed</th>
                                                <th class="text-center">At Risk</th>
                                                <th class="text-center">Avg Progress</th>
                                                <th></th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <t t-foreach="employee_data" t-as="data">
                                                <tr>
                                                    <td>
                                                        <div class="d-flex align-items-center">
                                                            <div class="bg-primary bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center me-2"
                                                                 style="width: 40px; height: 40px;">
                                                                <span class="text-primary fw-bold" 
                                                                      t-out="data['employee'].name[:1].upper()"/>
                                                            </div>
                                                            <div>
                                                                <span class="fw-semibold" t-out="data['employee'].name"/>
                                                                <t t-if="data['employee'].work_email">
                                                                    <small class="text-muted d-block" t-out="data['employee'].work_email"/>
                                                                </t>
                                                            </div>
                                                        </div>
                                                    </td>
                                                    <td>
                                                        <small t-out="data['employee'].department_id.name if data['employee'].department_id else '-'"/>
                                                    </td>
                                                    <td class="text-center">
                                                        <span class="badge bg-primary bg-opacity-10 text-primary" t-out="data['total_courses']"/>
                                                    </td>
                                                    <td class="text-center">
                                                        <span class="badge bg-info bg-opacity-10 text-info" t-out="data['in_progress']"/>
                                                    </td>
                                                    <td class="text-center">
                                                        <span class="badge bg-success bg-opacity-10 text-success" t-out="data['completed']"/>
                                                    </td>
                                                    <td class="text-center">
                                                        <t t-if="data['at_risk'] > 0">
                                                            <span class="badge bg-warning bg-opacity-10 text-warning" t-out="data['at_risk']"/>
                                                        </t>
                                                        <t t-else="">
                                                            <span class="badge bg-light text-muted">0</span>
                                                        </t>
                                                    </td>
                                                    <td class="text-center">
                                                        <div class="d-flex align-items-center justify-content-center">
                                                            <div class="progress me-2" style="width: 50px; height: 6px;">
                                                                <div class="progress-bar bg-primary" 
                                                                     t-attf-style="width: #{data['avg_completion']}%"/>
                                                            </div>
                                                            <small t-out="'{:.0f}%'.format(data['avg_completion'])"/>
                                                        </div>
                                                    </td>
                                                    <td>
                                                        <a t-attf-href="/hr/employee/#{data['employee'].id}" 
                                                           class="btn btn-sm btn-outline-primary">View</a>
                                                    </td>
                                                </tr>
                                            </t>
                                        </tbody>
                                    </table>
                                </div>
                            </t>
                            <t t-if="not employee_data">
                                <div class="text-center py-5">
                                    <i class="fa fa-users fa-3x text-muted mb-3"></i>
                                    <h5>No employees found</h5>
                                    <p class="text-muted">Try adjusting your search filters.</p>
                                </div>
                            </t>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>

</odoo>
