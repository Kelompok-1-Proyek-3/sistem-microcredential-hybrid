<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- HR Manager Dashboard                                         -->
    <!-- ============================================================ -->

    <template id="hr_dashboard" name="HR Learning Dashboard">
        <t t-call="website.layout">
            <t t-set="title">HR Learning Dashboard - IMPC</t>

            <div class="impc-dashboard py-4">
                <div class="container">
                    <!-- Header -->
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <div>
                            <h2 class="fw-bold mb-1">
                                <i class="fa fa-users text-primary me-2"></i>HR Learning Dashboard
                            </h2>
                            <p class="text-muted mb-0">Monitor employee learning progress and development</p>
                        </div>
                        <div>
                            <a href="/hr/analytics" class="btn btn-outline-primary me-2">
                                <i class="fa fa-chart-bar me-1"></i>Analytics
                            </a>
                            <a href="/hr/employees" class="btn btn-primary">
                                <i class="fa fa-user me-1"></i>All Employees
                            </a>
                        </div>
                    </div>

                    <!-- Stats Cards -->
                    <div class="row g-3 mb-4">
                        <div class="col-md-3">
                            <div class="card border-0 shadow-sm rounded-3 h-100">
                                <div class="card-body d-flex align-items-center p-3">
                                    <div class="bg-primary bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center me-3"
                                         style="width: 50px; height: 50px;">
                                        <i class="fa fa-book fa-lg text-primary"></i>
                                    </div>
                                    <div>
                                        <h4 class="fw-bold mb-0" t-out="total_in_learning"/>
                                        <small class="text-muted">Total in Learning</small>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="card border-0 shadow-sm rounded-3 h-100">
                                <div class="card-body d-flex align-items-center p-3">
                                    <div class="bg-info bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center me-3"
                                         style="width: 50px; height: 50px;">
                                        <i class="fa fa-spinner fa-lg text-info"></i>
                                    </div>
                                    <div>
                                        <h4 class="fw-bold mb-0" t-out="total_in_progress"/>
                                        <small class="text-muted">In Progress</small>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="card border-0 shadow-sm rounded-3 h-100">
                                <div class="card-body d-flex align-items-center p-3">
                                    <div class="bg-success bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center me-3"
                                         style="width: 50px; height: 50px;">
                                        <i class="fa fa-check-circle fa-lg text-success"></i>
                                    </div>
                                    <div>
                                        <h4 class="fw-bold mb-0" t-out="total_completed"/>
                                        <small class="text-muted">Completed</small>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="card border-0 shadow-sm rounded-3 h-100 border-warning">
                                <div class="card-body d-flex align-items-center p-3">
                                    <div class="bg-warning bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center me-3"
                                         style="width: 50px; height: 50px;">
                                        <i class="fa fa-exclamation-triangle fa-lg text-warning"></i>
                                    </div>
                                    <div>
                                        <h4 class="fw-bold mb-0" t-out="total_at_risk"/>
                                        <small class="text-muted">At Risk</small>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="row g-4">
                        <!-- Main Content -->
                        <div class="col-lg-8">
                            <!-- Department Overview -->
                            <div class="card border-0 shadow-sm rounded-3 mb-4">
                                <div class="card-header bg-white border-0 pt-3 px-4 d-flex justify-content-between align-items-center">
                                    <h5 class="fw-bold mb-0">
                                        <i class="fa fa-building text-primary me-2"></i>Department Overview
                                    </h5>
                                </div>
                                <div class="card-body px-4 pb-4">
                                    <t t-if="dept_stats">
                                        <div class="table-responsive">
                                            <table class="table table-hover align-middle mb-0">
                                                <thead class="table-light">
                                                    <tr>
                                                        <th>Department</th>
                                                        <th class="text-center">Enrolled</th>
                                                        <th class="text-center">Completed</th>
                                                        <th class="text-center">At Risk</th>
                                                        <th class="text-center">Avg Progress</th>
                                                        <th></th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    <t t-foreach="dept_stats" t-as="stat">
                                                        <tr>
                                                            <td>
                                                                <span class="fw-semibold" t-out="stat['department'].name"/>
                                                            </td>
                                                            <td class="text-center">
                                                                <span class="badge bg-primary bg-opacity-10 text-primary" t-out="stat['total']"/>
                                                            </td>
                                                            <td class="text-center">
                                                                <span class="badge bg-success bg-opacity-10 text-success" t-out="stat['completed']"/>
                                                            </td>
                                                            <td class="text-center">
                                                                <t t-if="stat['at_risk'] > 0">
                                                                    <span class="badge bg-warning bg-opacity-10 text-warning" t-out="stat['at_risk']"/>
                                                                </t>
                                                                <t t-else="">
                                                                    <span class="badge bg-light text-muted">0</span>
                                                                </t>
                                                            </td>
                                                            <td class="text-center">
                                                                <div class="d-flex align-items-center justify-content-center">
                                                                    <div class="progress flex-grow-1 me-2" style="height: 6px; max-width: 80px;">
                                                                        <div class="progress-bar bg-primary" 
                                                                             t-attf-style="width: #{stat['avg_completion']}%"/>
                                                                    </div>
                                                                    <small t-out="round(stat['avg_completion'], 1)"/>%
                                                                </div>
                                                            </td>
                                                            <td class="text-end">
                                                                <a t-attf-href="/hr/department/#{stat['department'].id}" 
                                                                   class="btn btn-sm btn-outline-primary">
                                                                    View
                                                                </a>
                                                            </td>
                                                        </tr>
                                                    </t>
                                                </tbody>
                                            </table>
                                        </div>
                                    </t>
                                    <t t-if="not dept_stats">
                                        <div class="text-center py-4">
                                            <i class="fa fa-building fa-2x text-muted mb-2"></i>
                                            <p class="text-muted mb-0">No department data available</p>
                                        </div>
                                    </t>
                                </div>
                            </div>

                            <!-- Recent Skill Updates -->
                            <div class="card border-0 shadow-sm rounded-3">
                                <div class="card-header bg-white border-0 pt-3 px-4">
                                    <h5 class="fw-bold mb-0">
                                        <i class="fa fa-star text-warning me-2"></i>Recent Skill Updates
                                    </h5>
                                </div>
                                <div class="card-body px-4 pb-4">
                                    <t t-if="recent_skill_logs">
                                        <t t-foreach="recent_skill_logs" t-as="log">
                                            <div class="d-flex align-items-center py-2 border-bottom">
                                                <div class="bg-warning bg-opacity-10 rounded p-2 me-3">
                                                    <i class="fa fa-arrow-up text-warning"></i>
                                                </div>
                                                <div class="flex-grow-1">
                                                    <small class="fw-bold d-block" t-out="log.employee_id.name"/>
                                                    <small class="text-muted">
                                                        <span t-out="log.skill_id.name"/> - 
                                                        <span t-out="log.skill_level_after_id.name"/>
                                                    </small>
                                                </div>
                                                <small class="text-muted" t-out="log.change_date"/>
                                            </div>
                                        </t>
                                    </t>
                                    <t t-if="not recent_skill_logs">
                                        <div class="text-center py-3">
                                            <p class="text-muted mb-0">No recent skill updates</p>
                                        </div>
                                    </t>
                                </div>
                            </div>
                        </div>

                        <!-- Sidebar -->
                        <div class="col-lg-4">
                            <!-- At Risk Alert -->
                            <t t-if="total_at_risk > 0">
                                <div class="card border-0 shadow-sm rounded-3 mb-4 border-warning">
                                    <div class="card-body p-3">
                                        <div class="d-flex align-items-center mb-3">
                                            <div class="bg-warning bg-opacity-10 rounded p-2 me-2">
                                                <i class="fa fa-exclamation-triangle text-warning"></i>
                                            </div>
                                            <h6 class="fw-bold mb-0">At-Risk Employees</h6>
                                        </div>
                                        <t t-foreach="at_risk_employees[:5]" t-as="rec">
                                            <div class="d-flex align-items-center py-2 border-bottom">
                                                <div class="flex-grow-1">
                                                    <small class="fw-bold d-block" t-out="rec.employee_id.name"/>
                                                    <small class="text-muted" t-out="rec.course_name"/>
                                                </div>
                                                <small class="text-warning fw-bold" t-out="'{}%'.format(rec.completion_percentage)"/>
                                            </div>
                                        </t>
                                        <a href="/hr/at-risk" class="btn btn-sm btn-outline-warning mt-3 w-100">
                                            View All At-Risk
                                        </a>
                                    </div>
                                </div>
                            </t>

                            <!-- Quick Actions -->
                            <div class="card border-0 shadow-sm rounded-3 mb-4">
                                <div class="card-body p-3">
                                    <h6 class="fw-bold mb-3">Quick Actions</h6>
                                    <div class="d-grid gap-2">
                                        <a href="/hr/employees" class="btn btn-outline-primary btn-sm text-start">
                                            <i class="fa fa-users me-2"></i>View All Employees
                                        </a>
                                        <a href="/hr/at-risk" class="btn btn-outline-warning btn-sm text-start">
                                            <i class="fa fa-exclamation-triangle me-2"></i>At-Risk Report
                                        </a>
                                        <a href="/hr/analytics" class="btn btn-outline-info btn-sm text-start">
                                            <i class="fa fa-chart-bar me-2"></i>Analytics
                                        </a>
                                    </div>
                                </div>
                            </div>

                            <!-- Recent Notes -->
                            <t t-if="recent_notes">
                                <div class="card border-0 shadow-sm rounded-3">
                                    <div class="card-body p-3">
                                        <h6 class="fw-bold mb-3">
                                            <i class="fa fa-sticky-note text-info me-2"></i>Recent Notes
                                        </h6>
                                        <t t-foreach="recent_notes" t-as="note">
                                            <div class="border-bottom pb-2 mb-2">
                                                <small class="fw-bold d-block" t-out="note.employee_id.name"/>
                                                <small class="text-muted" t-out="note.note_text[:50] + ('...' if len(note.note_text) > 50 else '')"/>
                                                <small class="text-muted d-block mt-1" t-out="note.note_date"/>
                                            </div>
                                        </t>
                                    </div>
                                </div>
                            </t>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <!-- ============================================================ -->
    <!-- At-Risk Employees List                                       -->
    <!-- ============================================================ -->

    <template id="hr_at_risk_list" name="At-Risk Employees">
        <t t-call="website.layout">
            <t t-set="title">At-Risk Employees - HR Dashboard</t>

            <div class="impc-dashboard py-4">
                <div class="container">
                    <!-- Header -->
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <div>
                            <h2 class="fw-bold mb-1">
                                <i class="fa fa-exclamation-triangle text-warning me-2"></i>At-Risk Employees
                            </h2>
                            <p class="text-muted mb-0">Employees with learning progress below threshold</p>
                        </div>
                        <a href="/hr/dashboard" class="btn btn-outline-primary">
                            <i class="fa fa-arrow-left me-1"></i>Back to Dashboard
                        </a>
                    </div>

                    <!-- Filter -->
                    <div class="card border-0 shadow-sm rounded-3 mb-4">
                        <div class="card-body p-3">
                            <form method="get" class="row g-3 align-items-end">
                                <div class="col-md-4">
                                    <label class="form-label small">Filter by Department</label>
                                    <select name="department_id" class="form-select">
                                        <option value="">All Departments</option>
                                        <t t-foreach="departments" t-as="dept">
                                            <option t-att-value="dept.id" t-att-selected="selected_department == dept.id">
                                                <span t-out="dept.name"/>
                                            </option>
                                        </t>
                                    </select>
                                </div>
                                <div class="col-md-2">
                                    <button type="submit" class="btn btn-primary w-100">Filter</button>
                                </div>
                            </form>
                        </div>
                    </div>

                    <!-- Stats -->
                    <div class="alert alert-warning d-flex align-items-center mb-4">
                        <i class="fa fa-exclamation-triangle me-2"></i>
                        <strong t-out="total_at_risk"/> employees at risk
                    </div>

                    <!-- At-Risk List by Department -->
                    <t t-if="dept_groups">
                        <t t-foreach="dept_groups.items()" t-as="dept_item">
                            <div class="card border-0 shadow-sm rounded-3 mb-4">
                                <div class="card-header bg-white border-0 pt-3 px-4">
                                    <h5 class="fw-bold mb-0" t-out="dept_item[0]"/>
                                </div>
                                <div class="card-body px-4 pb-4">
                                    <div class="table-responsive">
                                        <table class="table table-hover align-middle mb-0">
                                            <thead class="table-light">
                                                <tr>
                                                    <th>Employee</th>
                                                    <th>Course</th>
                                                    <th class="text-center">Progress</th>
                                                    <th class="text-center">Enrolled</th>
                                                    <th class="text-center">Last Accessed</th>
                                                    <th></th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <t t-foreach="dept_item[1]" t-as="rec">
                                                    <tr>
                                                        <td>
                                                            <a t-attf-href="/hr/employee/#{rec.employee_id.id}">
                                                                <span t-out="rec.employee_id.name"/>
                                                            </a>
                                                        </td>
                                                        <td>
                                                            <small t-out="rec.course_name"/>
                                                        </td>
                                                        <td class="text-center">
                                                            <div class="d-flex align-items-center justify-content-center">
                                                                <div class="progress me-2" style="width: 60px; height: 8px;">
                                                                    <div class="progress-bar bg-warning" 
                                                                         t-attf-style="width: #{rec.completion_percentage}%"/>
                                                                </div>
                                                                <small t-out="'{}%'.format(rec.completion_percentage)"/>
                                                            </div>
                                                        </td>
                                                        <td class="text-center">
                                                            <small t-out="rec.enrollment_date" t-options="{'widget': 'date'}"/>
                                                        </td>
                                                        <td class="text-center">
                                                            <small t-out="rec.last_accessed_date" t-options="{'widget': 'datetime'}"/>
                                                        </td>
                                                        <td>
                                                            <a t-attf-href="/hr/employee/#{rec.employee_id.id}" 
                                                               class="btn btn-sm btn-outline-primary">
                                                                View
                                                            </a>
                                                        </td>
                                                    </tr>
                                                </t>
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </t>
                    <t t-if="not dept_groups">
                        <div class="card border-0 shadow-sm rounded-3">
                            <div class="card-body text-center py-5">
                                <i class="fa fa-check-circle fa-3x text-success mb-3"></i>
                                <h5>No at-risk employees</h5>
                                <p class="text-muted">All employees are on track with their learning.</p>
                            </div>
                        </div>
                    </t>
                </div>
            </div>
        </t>
    </template>

    <!-- ============================================================ -->
    <!-- Department Detail                                            -->
    <!-- ============================================================ -->

    <template id="hr_department_detail" name="Department Learning Detail">
        <t t-call="website.layout">
            <t t-set="title" t-out="'{} - HR Dashboard'.format(department.name)"/>

            <div class="impc-dashboard py-4">
                <div class="container">
                    <!-- Header -->
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <div>
                            <nav aria-label="breadcrumb">
                                <ol class="breadcrumb mb-1">
                                    <li class="breadcrumb-item"><a href="/hr/dashboard">HR Dashboard</a></li>
                                    <li class="breadcrumb-item active" t-out="department.name"/>
                                </ol>
                            </nav>
                            <h2 class="fw-bold mb-0" t-out="department.name"/>
                        </div>
                        <a href="/hr/analytics/department/{department.id}" class="btn btn-outline-info">
                            <i class="fa fa-chart-bar me-1"></i>View Analytics
                        </a>
                    </div>

                    <!-- Stats -->
                    <div class="row g-3 mb-4">
                        <div class="col-md-3">
                            <div class="card border-0 shadow-sm rounded-3">
                                <div class="card-body text-center p-3">
                                    <h3 class="fw-bold mb-0" t-out="total_employees"/>
                                    <small class="text-muted">Employees in Learning</small>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="card border-0 shadow-sm rounded-3">
                                <div class="card-body text-center p-3">
                                    <h3 class="fw-bold text-info mb-0" t-out="in_progress_count"/>
                                    <small class="text-muted">In Progress</small>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="card border-0 shadow-sm rounded-3">
                                <div class="card-body text-center p-3">
                                    <h3 class="fw-bold text-success mb-0" t-out="completed_count"/>
                                    <small class="text-muted">Completed</small>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="card border-0 shadow-sm rounded-3">
                                <div class="card-body text-center p-3">
                                    <h3 class="fw-bold mb-0" t-out="'{:.1f}%'.format(avg_completion)"/>
                                    <small class="text-muted">Avg Completion</small>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Employee List -->
                    <div class="card border-0 shadow-sm rounded-3">
                        <div class="card-header bg-white border-0 pt-3 px-4">
                            <h5 class="fw-bold mb-0">Learning Progress</h5>
                        </div>
                        <div class="card-body px-4 pb-4">
                            <div class="table-responsive">
                                <table class="table table-hover align-middle">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Employee</th>
                                            <th>Course</th>
                                            <th class="text-center">Progress</th>
                                            <th class="text-center">Status</th>
                                            <th class="text-center">Last Accessed</th>
                                            <th></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-foreach="progress_records" t-as="rec">
                                            <tr>
                                                <td>
                                                    <a t-attf-href="/hr/employee/#{rec.employee_id.id}">
                                                        <span t-out="rec.employee_id.name"/>
                                                    </a>
                                                </td>
                                                <td>
                                                    <small t-out="rec.course_name"/>
                                                </td>
                                                <td class="text-center">
                                                    <div class="d-flex align-items-center justify-content-center">
                                                        <div class="progress me-2" style="width: 60px; height: 8px;">
                                                            <div class="progress-bar" 
                                                                 t-attf-class="bg-#{rec.status == 'completed' and 'success' or rec.status == 'at_risk' and 'warning' or 'primary'}"
                                                                 t-attf-style="width: #{rec.completion_percentage}%"/>
                                                        </div>
                                                        <small t-out="'{}%'.format(rec.completion_percentage)"/>
                                                    </div>
                                                </td>
                                                <td class="text-center">
                                                    <span t-attf-class="badge bg-#{rec.status == 'completed' and 'success' or rec.status == 'at_risk' and 'warning' or 'info'} bg-opacity-10 text-#{rec.status == 'completed' and 'success' or rec.status == 'at_risk' and 'warning' or 'info'}">
                                                        <span t-out="rec.status.replace('_', ' ').title()"/>
                                                    </span>
                                                </td>
                                                <td class="text-center">
                                                    <small t-out="rec.last_accessed_date" t-options="{'widget': 'datetime'}"/>
                                                </td>
                                                <td>
                                                    <a t-attf-href="/hr/employee/#{rec.employee_id.id}" 
                                                       class="btn btn-sm btn-outline-primary">View</a>
                                                </td>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>

</odoo>
