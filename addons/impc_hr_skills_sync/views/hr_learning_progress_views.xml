<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hr_learning_progress_list" model="ir.ui.view">
        <field name="name">hr.learning.progress.list</field>
        <field name="model">hr.learning.progress</field>
        <field name="arch" type="xml">
            <list string="Learning Progress" decoration-danger="status == 'at_risk'" decoration-success="status == 'completed'" decoration-info="status == 'in_progress'">
                <field name="employee_id"/>
                <field name="course_name"/>
                <field name="learning_mode"/>
                <field name="enrollment_date"/>
                <field name="completion_percentage" widget="progressbar"/>
                <field name="attendance_status"/>
                <field name="status" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="view_hr_learning_progress_search" model="ir.ui.view">
        <field name="name">hr.learning.progress.search</field>
        <field name="model">hr.learning.progress</field>
        <field name="arch" type="xml">
            <search string="Search Learning Progress">
                <field name="employee_id"/>
                <field name="course_name"/>
                <filter string="At Risk" name="at_risk" domain="[('status','=','at_risk')]"/>
                <filter string="Completed" name="completed" domain="[('status','=','completed')]"/>
                <filter string="In Progress" name="in_progress" domain="[('status','=','in_progress')]"/>
                <separator/>
                <filter string="Employee" name="group_by_employee" context="{'group_by':'employee_id'}"/>
                <filter string="Course" name="group_by_course" context="{'group_by':'channel_id'}"/>
                <filter string="Status" name="group_by_status" context="{'group_by':'status'}"/>
            </search>
        </field>
    </record>

    <record id="action_hr_learning_progress" model="ir.actions.act_window">
        <field name="name">Progress Dashboard</field>
        <field name="res_model">hr.learning.progress</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_hr_learning_progress_search"/>
        <field name="context">{'search_default_group_by_course': 1}</field>
    </record>

    <record id="action_hr_learning_at_risk" model="ir.actions.act_window">
        <field name="name">At-Risk Employees</field>
        <field name="res_model">hr.learning.progress</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_hr_learning_progress_search"/>
        <field name="domain">[('status', '=', 'at_risk')]</field>
        <field name="context">{'search_default_at_risk': 1}</field>
    </record>
</odoo>
