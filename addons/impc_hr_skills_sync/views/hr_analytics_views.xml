<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- HR Analytics Dashboard                                       -->
    <!-- ============================================================ -->

    <template id="hr_analytics_dashboard" name="HR Learning Analytics">
        <t t-call="website.layout">
            <t t-set="title">Learning Analytics - HR Dashboard</t>

            <div class="impc-dashboard py-4">
                <div class="container">
                    <!-- Header -->
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <div>
                            <h2 class="fw-bold mb-1">
                                <i class="fa fa-chart-bar text-primary me-2"></i>Learning Analytics
                            </h2>
                            <p class="text-muted mb-0">Visual insights into employee learning progress</p>
                        </div>
                        <div>
                            <a href="/hr/dashboard" class="btn btn-outline-primary">
                                <i class="fa fa-arrow-left me-1"></i>Back to Dashboard
                            </a>
                        </div>
                    </div>

                    <!-- Period Selector -->
                    <div class="card border-0 shadow-sm rounded-3 mb-4">
                        <div class="card-body p-3">
                            <div class="btn-group" role="group">
                                <a t-attf-href="/hr/analytics?period=week" 
                                   t-attf-class="btn btn-sm #{period == 'week' and 'btn-primary' or 'btn-outline-primary'}">Last 7 Days</a>
                                <a t-attf-href="/hr/analytics?period=month" 
                                   t-attf-class="btn btn-sm #{period == 'month' and 'btn-primary' or 'btn-outline-primary'}">Last 30 Days</a>
                                <a t-attf-href="/hr/analytics?period=quarter" 
                                   t-attf-class="btn btn-sm #{period == 'quarter' and 'btn-primary' or 'btn-outline-primary'}">Last 90 Days</a>
                            </div>
                        </div>
                    </div>

                    <!-- Charts Row 1 -->
                    <div class="row g-4 mb-4">
                        <!-- Status Distribution -->
                        <div class="col-lg-4">
                            <div class="card border-0 shadow-sm rounded-3 h-100">
                                <div class="card-header bg-white border-0 pt-3 px-4">
                                    <h5 class="fw-bold mb-0">
                                        <i class="fa fa-pie-chart text-info me-2"></i>Status Distribution
                                    </h5>
                                </div>
                                <div class="card-body px-4 pb-4">
                                    <div id="status-chart" style="height: 250px;"></div>
                                </div>
                            </div>
                        </div>

                        <!-- Department Enrollment -->
                        <div class="col-lg-8">
                            <div class="card border-0 shadow-sm rounded-3 h-100">
                                <div class="card-header bg-white border-0 pt-3 px-4">
                                    <h5 class="fw-bold mb-0">
                                        <i class="fa fa-building text-primary me-2"></i>Department Enrollment
                                    </h5>
                                </div>
                                <div class="card-body px-4 pb-4">
                                    <div id="dept-chart" style="height: 250px;"></div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Charts Row 2 -->
                    <div class="row g-4 mb-4">
                        <!-- Top Courses -->
                        <div class="col-lg-6">
                            <div class="card border-0 shadow-sm rounded-3 h-100">
                                <div class="card-header bg-white border-0 pt-3 px-4">
                                    <h5 class="fw-bold mb-0">
                                        <i class="fa fa-star text-warning me-2"></i>Top Courses
                                    </h5>
                                </div>
                                <div class="card-body px-4 pb-4">
                                    <t t-if="top_courses">
                                        <div class="table-responsive">
                                            <table class="table table-hover align-middle mb-0">
                                                <thead class="table-light">
                                                    <tr>
                                                        <th>Course</th>
                                                        <th class="text-center">Enrolled</th>
                                                        <th class="text-center">Completed</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    <t t-foreach="top_courses" t-as="course">
                                                        <tr>
                                                            <td>
                                                                <small class="fw-semibold" t-out="course['name']"/>
                                                            </td>
                                                            <td class="text-center">
                                                                <span class="badge bg-primary bg-opacity-10 text-primary" t-out="course['total']"/>
                                                            </td>
                                                            <td class="text-center">
                                                                <span class="badge bg-success bg-opacity-10 text-success" t-out="course['completed']"/>
                                                            </td>
                                                        </tr>
                                                    </t>
                                                </tbody>
                                            </table>
                                        </div>
                                    </t>
                                    <t t-if="not top_courses">
                                        <div class="text-center py-4">
                                            <p class="text-muted mb-0">No course data available</p>
                                        </div>
                                    </t>
                                </div>
                            </div>
                        </div>

                        <!-- Skill Trends -->
                        <div class="col-lg-6">
                            <div class="card border-0 shadow-sm rounded-3 h-100">
                                <div class="card-header bg-white border-0 pt-3 px-4">
                                    <h5 class="fw-bold mb-0">
                                        <i class="fa fa-arrow-trend text-success me-2"></i>Skill Acquisition Trends
                                    </h5>
                                </div>
                                <div class="card-body px-4 pb-4">
                                    <t t-if="skill_trends">
                                        <t t-foreach="skill_trends" t-as="skill">
                                            <div class="d-flex align-items-center py-2 border-bottom">
                                                <div class="bg-success bg-opacity-10 rounded p-2 me-3">
                                                    <i class="fa fa-check text-success"></i>
                                                </div>
                                                <div class="flex-grow-1">
                                                    <small class="fw-bold" t-out="skill['skill']"/>
                                                </div>
                                                <span class="badge bg-success" t-out="skill['count']"/>
                                            </div>
                                        </t>
                                    </t>
                                    <t t-if="not skill_trends">
                                        <div class="text-center py-4">
                                            <p class="text-muted mb-0">No skill data available</p>
                                        </div>
                                    </t>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Department Table -->
                    <div class="card border-0 shadow-sm rounded-3">
                        <div class="card-header bg-white border-0 pt-3 px-4 d-flex justify-content-between align-items-center">
                            <h5 class="fw-bold mb-0">
                                <i class="fa fa-table text-secondary me-2"></i>Department Statistics
                            </h5>
                        </div>
                        <div class="card-body px-4 pb-4">
                            <t t-if="dept_enrollment">
                                <div class="table-responsive">
                                    <table class="table table-hover align-middle">
                                        <thead class="table-light">
                                            <tr>
                                                <th>Department</th>
                                                <th class="text-center">Enrolled</th>
                                                <th class="text-center">Avg Completion</th>
                                                <th class="text-center">At Risk</th>
                                                <th></th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <t t-foreach="dept_enrollment" t-as="dept">
                                                <tr>
                                                    <td>
                                                        <span class="fw-semibold" t-out="dept['department']"/>
                                                    </td>
                                                    <td class="text-center">
                                                        <span class="badge bg-primary" t-out="dept['total']"/>
                                                    </td>
                                                    <td class="text-center">
                                                        <div class="d-flex align-items-center justify-content-center">
                                                            <div class="progress me-2" style="width: 80px; height: 8px;">
                                                                <div class="progress-bar bg-primary" 
                                                                     t-attf-style="width: #{dept['avg_completion']}%"/>
                                                            </div>
                                                            <small t-out="'{:.1f}%'.format(dept['avg_completion'])"/>
                                                        </div>
                                                    </td>
                                                    <td class="text-center">
                                                        <t t-if="dept['at_risk'] > 0">
                                                            <span class="badge bg-warning" t-out="dept['at_risk']"/>
                                                        </t>
                                                        <t t-else="">
                                                            <span class="badge bg-light text-muted">0</span>
                                                        </t>
                                                    </td>
                                                    <td class="text-end">
                                                        <a t-attf-href="/hr/analytics/department/#{loop.index}" 
                                                           class="btn btn-sm btn-outline-info">
                                                            Details
                                                        </a>
                                                    </td>
                                                </tr>
                                            </t>
                                        </tbody>
                                    </table>
                                </div>
                            </t>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Chart.js Scripts -->
            <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
            <script>
                (function() {
                    // Status Distribution Chart
                    var statusData = <t t-raw="status_chart_data"/>;
                    var statusCtx = document.getElementById('status-chart');
                    if (statusCtx) {
                        new Chart(statusCtx, {
                            type: 'doughnut',
                            data: {
                                labels: statusData.labels,
                                datasets: [{
                                    data: statusData.data,
                                    backgroundColor: ['#0dcaf0', '#198754', '#ffc107'],
                                    borderWidth: 0
                                }]
                            },
                            options: {
                                responsive: true,
                                maintainAspectRatio: false,
                                plugins: {
                                    legend: {
                                        position: 'bottom'
                                    }
                                }
                            }
                        });
                    }

                    // Department Chart
                    var deptData = <t t-raw="dept_chart_data"/>;
                    var deptCtx = document.getElementById('dept-chart');
                    if (deptCtx && deptData.labels.length > 0) {
                        new Chart(deptCtx, {
                            type: 'bar',
                            data: {
                                labels: deptData.labels,
                                datasets: [
                                    {
                                        label: 'Enrolled',
                                        data: deptData.datasets.total,
                                        backgroundColor: '#0d6efd',
                                        borderRadius: 4
                                    },
                                    {
                                        label: 'Completed',
                                        data: deptData.datasets.completed,
                                        backgroundColor: '#198754',
                                        borderRadius: 4
                                    }
                                ]
                            },
                            options: {
                                responsive: true,
                                maintainAspectRatio: false,
                                scales: {
                                    y: {
                                        beginAtZero: true
                                    }
                                },
                                plugins: {
                                    legend: {
                                        position: 'top'
                                    }
                                }
                            }
                        });
                    }
                })();
            </script>
        </t>
    </template>

    <!-- ============================================================ -->
    <!-- Department Analytics                                         -->
    <!-- ============================================================ -->

    <template id="hr_department_analytics" name="Department Analytics">
        <t t-call="website.layout">
            <t t-set="title" t-out="'{} - Analytics'.format(department.name)"/>

            <div class="impc-dashboard py-4">
                <div class="container">
                    <!-- Header -->
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <div>
                            <nav aria-label="breadcrumb">
                                <ol class="breadcrumb mb-1">
                                    <li class="breadcrumb-item"><a href="/hr/analytics">Analytics</a></li>
                                    <li class="breadcrumb-item active" t-out="department.name"/>
                                </ol>
                            </nav>
                            <h2 class="fw-bold mb-0" t-out="department.name"/>
                        </div>
                        <a href="/hr/analytics" class="btn btn-outline-primary">
                            <i class="fa fa-arrow-left me-1"></i>Back to Analytics
                        </a>
                    </div>

                    <!-- Stats -->
                    <div class="row g-3 mb-4">
                        <div class="col-md-3">
                            <div class="card border-0 shadow-sm rounded-3">
                                <div class="card-body text-center p-3">
                                    <h3 class="fw-bold mb-0" t-out="total_employees"/>
                                    <small class="text-muted">Employees Learning</small>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="card border-0 shadow-sm rounded-3">
                                <div class="card-body text-center p-3">
                                    <h3 class="fw-bold mb-0" t-out="total_courses"/>
                                    <small class="text-muted">Courses Enrolled</small>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="card border-0 shadow-sm rounded-3">
                                <div class="card-body text-center p-3">
                                    <h3 class="fw-bold mb-0">
                                        <t t-if="snapshots">
                                            <span t-out="'{:.1f}%'.format(snapshots[0].completion_rate)"/>
                                        </t>
                                        <t t-else="">-</t>
                                    </h3>
                                    <small class="text-muted">Completion Rate</small>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="card border-0 shadow-sm rounded-3">
                                <div class="card-body text-center p-3">
                                    <h3 class="fw-bold text-warning mb-0">
                                        <t t-if="snapshots">
                                            <span t-out="snapshots[0].at_risk_count"/>
                                        </t>
                                        <t t-else="">0</t>
                                    </h3>
                                    <small class="text-muted">At Risk</small>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="row g-4">
                        <!-- Progress Distribution -->
                        <div class="col-lg-6">
                            <div class="card border-0 shadow-sm rounded-3 h-100">
                                <div class="card-header bg-white border-0 pt-3 px-4">
                                    <h5 class="fw-bold mb-0">
                                        <i class="fa fa-chart-bar text-primary me-2"></i>Progress Distribution
                                    </h5>
                                </div>
                                <div class="card-body px-4 pb-4">
                                    <div id="progress-chart" style="height: 300px;"></div>
                                </div>
                            </div>
                        </div>

                        <!-- Timeline -->
                        <div class="col-lg-6">
                            <div class="card border-0 shadow-sm rounded-3 h-100">
                                <div class="card-header bg-white border-0 pt-3 px-4">
                                    <h5 class="fw-bold mb-0">
                                        <i class="fa fa-chart-line text-info me-2"></i>Timeline
                                    </h5>
                                </div>
                                <div class="card-body px-4 pb-4">
                                    <div id="timeline-chart" style="height: 300px;"></div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Employee Table -->
                    <div class="card border-0 shadow-sm rounded-3 mt-4">
                        <div class="card-header bg-white border-0 pt-3 px-4">
                            <h5 class="fw-bold mb-0">Employee Learning Details</h5>
                        </div>
                        <div class="card-body px-4 pb-4">
                            <div class="table-responsive">
                                <table class="table table-hover align-middle">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Employee</th>
                                            <th>Course</th>
                                            <th class="text-center">Progress</th>
                                            <th class="text-center">Status</th>
                                            <th class="text-center">Last Accessed</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-foreach="employee_data" t-as="data">
                                            <tr>
                                                <td>
                                                    <a t-attf-href="/hr/employee/#{data['employee'].id}">
                                                        <span t-out="data['employee'].name"/>
                                                    </a>
                                                </td>
                                                <td>
                                                    <small t-out="data['course'].name"/>
                                                </td>
                                                <td class="text-center">
                                                    <div class="d-flex align-items-center justify-content-center">
                                                        <div class="progress me-2" style="width: 60px; height: 8px;">
                                                            <div class="progress-bar bg-primary" 
                                                                 t-attf-style="width: #{data['completion']}%"/>
                                                        </div>
                                                        <small t-out="'{}%'.format(data['completion'])"/>
                                                    </div>
                                                </td>
                                                <td class="text-center">
                                                    <span t-attf-class="badge bg-#{data['status'] == 'completed' and 'success' or data['status'] == 'at_risk' and 'warning' or 'info'}">
                                                        <span t-out="data['status'].replace('_', ' ').title()"/>
                                                    </span>
                                                </td>
                                                <td class="text-center">
                                                    <small t-out="data['last_accessed']" t-options="{'widget': 'date'}"/>
                                                </td>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Chart.js Scripts -->
            <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
            <script>
                (function() {
                    // Progress Chart
                    var progressData = <t t-raw="progress_chart_data"/>;
                    var progressCtx = document.getElementById('progress-chart');
                    if (progressCtx) {
                        new Chart(progressCtx, {
                            type: 'bar',
                            data: {
                                labels: progressData.labels,
                                datasets: [{
                                    label: 'Employees',
                                    data: progressData.data,
                                    backgroundColor: ['#dc3545', '#ffc107', '#0dcaf0', '#0d6efd', '#198754'],
                                    borderRadius: 4
                                }]
                            },
                            options: {
                                responsive: true,
                                maintainAspectRatio: false,
                                indexAxis: 'y',
                                plugins: {
                                    legend: {
                                        display: false
                                    }
                                }
                            }
                        });
                    }

                    // Timeline Chart
                    var timelineData = <t t-raw="timeline_chart_data"/>;
                    var timelineCtx = document.getElementById('timeline-chart');
                    if (timelineCtx && timelineData.labels.length > 0) {
                        new Chart(timelineCtx, {
                            type: 'line',
                            data: {
                                labels: timelineData.labels,
                                datasets: [{
                                    label: 'Completion Rate (%)',
                                    data: timelineData.completion_rate,
                                    borderColor: '#0d6efd',
                                    backgroundColor: 'rgba(13, 110, 253, 0.1)',
                                    fill: true,
                                    tension: 0.3
                                }]
                            },
                            options: {
                                responsive: true,
                                maintainAspectRatio: false,
                                scales: {
                                    y: {
                                        beginAtZero: true,
                                        max: 100
                                    }
                                }
                            }
                        });
                    }
                })();
            </script>
        </t>
    </template>

</odoo>
