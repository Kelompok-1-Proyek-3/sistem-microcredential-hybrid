<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_lms_learner_list" model="ir.ui.view">
        <field name="name">lms.learner.list</field>
        <field name="model">lms.learner</field>
        <field name="arch" type="xml">
            <list>
                <field name="partner_id"/>
                <field name="learner_type"/>
                <field name="company_id"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_lms_learner_form" model="ir.ui.view">
        <field name="name">lms.learner.form</field>
        <field name="model">lms.learner</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="partner_id"/>
                        <field name="learner_type"/>
                        <field name="company_id"/>
                        <field name="active"/>
                    </group>
                    <notebook>
                        <page string="Enrollments">
                            <field name="enrollment_ids">
                                <list>
                                    <field name="channel_id"/>
                                    <field name="status"/>
                                    <field name="progress_pct"/>
                                </list>
                            </field>
                        </page>
                        <page string="Certificates">
                            <field name="certificate_ids">
                                <list>
                                    <field name="channel_id"/>
                                    <field name="issued_date"/>
                                    <field name="skill_synced"/>
                                </list>
                            </field>
                        </page>
                        <page string="Competencies">
                            <field name="competency_ids">
                                <list>
                                    <field name="competency_name"/>
                                    <field name="competency_level"/>
                                    <field name="acquired_date"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_lms_learners" model="ir.actions.act_window">
        <field name="name">Learners</field>
        <field name="res_model">lms.learner</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
