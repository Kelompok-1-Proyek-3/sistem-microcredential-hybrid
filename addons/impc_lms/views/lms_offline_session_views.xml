<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_lms_offline_session_list" model="ir.ui.view">
        <field name="name">lms.offline.session.list</field>
        <field name="model">lms.offline_session</field>
        <field name="arch" type="xml">
            <list>
                <field name="channel_id"/>
                <field name="session_date"/>
                <field name="start_time"/>
                <field name="end_time"/>
                <field name="location"/>
                <field name="capacity"/>
                <field name="enrolled_count"/>
                <field name="is_active"/>
            </list>
        </field>
    </record>

    <record id="view_lms_offline_session_form" model="ir.ui.view">
        <field name="name">lms.offline.session.form</field>
        <field name="model">lms.offline_session</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="channel_id"/>
                        <field name="session_date"/>
                        <field name="location"/>
                    </group>
                    <group>
                        <field name="start_time"/>
                        <field name="end_time"/>
                        <field name="capacity"/>
                        <field name="is_active"/>
                    </group>
                    <group>
                        <field name="enrolled_count" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_lms_offline_sessions" model="ir.actions.act_window">
        <field name="name">Offline Sessions</field>
        <field name="res_model">lms.offline_session</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
