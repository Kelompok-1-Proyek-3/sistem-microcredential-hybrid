<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_lms_enrollment_list" model="ir.ui.view">
        <field name="name">lms.enrollment.list</field>
        <field name="model">lms.enrollment</field>
        <field name="arch" type="xml">
            <list>
                <field name="learner_id"/>
                <field name="channel_id"/>
                <field name="status"/>
                <field name="progress_pct"/>
                <field name="attendance_status"/>
            </list>
        </field>
    </record>

    <record id="view_lms_enrollment_form" model="ir.ui.view">
        <field name="name">lms.enrollment.form</field>
        <field name="model">lms.enrollment</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="learner_id"/>
                        <field name="channel_id"/>
                        <field name="enrollment_type"/>
                        <field name="status"/>
                    </group>
                    <group>
                        <field name="enrollment_date"/>
                        <field name="progress_pct"/>
                        <field name="last_activity_date"/>
                    </group>
                    <group>
                        <field name="requires_offline"/>
                        <field name="attendance_status"/>
                        <field name="exam_unlocked"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_lms_enrollments" model="ir.actions.act_window">
        <field name="name">Enrollments</field>
        <field name="res_model">lms.enrollment</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
