<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- IMPC Administrator Management Dashboard                      -->
    <!-- ============================================================ -->

    <template id="admin_dashboard" name="IMPC Admin - Management Dashboard">
        <t t-call="website.layout">
            <t t-set="title">Management Dashboard - IMPC</t>

            <div class="impc-admin-dashboard py-4" style="background: #f8f9fa; min-height: 80vh;">
                <div class="container-xl">

                    <!-- Page Header -->
                    <div class="d-flex align-items-center justify-content-between mb-4">
                        <div>
                            <h2 class="fw-bold mb-1" style="color: var(--impc-secondary);">
                                <i class="fa fa-tachometer me-2"/>Platform Management Dashboard
                            </h2>
                            <p class="text-muted mb-0">
                                Welcome, <strong t-out="request.env.user.name"/>. Platform operational overview.
                            </p>
                        </div>
                        <div class="d-flex gap-2">
                            <a href="/web" class="btn btn-outline-secondary btn-sm">
                                <i class="fa fa-cog me-1"/>Open Backend
                            </a>
                        </div>
                    </div>

                    <!-- ================================================ -->
                    <!-- Stats Widgets Row 1                               -->
                    <!-- ================================================ -->
                    <div class="row g-3 mb-4">

                        <!-- Pending Course Approvals -->
                        <div class="col-sm-6 col-lg-3">
                            <div class="card border-0 shadow-sm h-100 position-relative overflow-hidden"
                                 style="border-radius: var(--impc-border-radius); border-left: 4px solid #ffc107 !important;">
                                <div class="card-body p-3">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <div>
                                            <p class="text-muted small mb-1 fw-semibold text-uppercase" style="font-size:0.7rem; letter-spacing:0.5px;">Pending Courses</p>
                                            <h3 class="fw-bold mb-0" style="font-size:2rem; color:#ffc107;">
                                                <t t-out="pending_courses_count"/>
                                            </h3>
                                            <small class="text-muted">Awaiting review</small>
                                        </div>
                                        <div class="rounded-circle d-flex align-items-center justify-content-center"
                                             style="width:48px;height:48px;background:rgba(255,193,7,0.15);">
                                            <i class="fa fa-book fa-lg" style="color:#ffc107;"/>
                                        </div>
                                    </div>
                                    <a href="/management/approvals/courses" class="btn btn-warning btn-sm mt-2 w-100">Review Courses</a>
                                </div>
                            </div>
                        </div>

                        <!-- Pending Event Approvals -->
                        <div class="col-sm-6 col-lg-3">
                            <div class="card border-0 shadow-sm h-100 position-relative overflow-hidden"
                                 style="border-radius: var(--impc-border-radius); border-left: 4px solid #dc3545 !important;">
                                <div class="card-body p-3">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <div>
                                            <p class="text-muted small mb-1 fw-semibold text-uppercase" style="font-size:0.7rem; letter-spacing:0.5px;">Pending Events</p>
                                            <h3 class="fw-bold mb-0" style="font-size:2rem; color:#dc3545;">
                                                <t t-out="pending_events_count"/>
                                            </h3>
                                            <small class="text-muted">Awaiting review</small>
                                        </div>
                                        <div class="rounded-circle d-flex align-items-center justify-content-center"
                                             style="width:48px;height:48px;background:rgba(220,53,69,0.15);">
                                            <i class="fa fa-calendar fa-lg" style="color:#dc3545;"/>
                                        </div>
                                    </div>
                                    <a href="/management/approvals/events" class="btn btn-danger btn-sm mt-2 w-100">Review Events</a>
                                </div>
                            </div>
                        </div>

                        <!-- Published Courses -->
                        <div class="col-sm-6 col-lg-3">
                            <div class="card border-0 shadow-sm h-100"
                                 style="border-radius: var(--impc-border-radius); border-left: 4px solid #198754 !important;">
                                <div class="card-body p-3">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <div>
                                            <p class="text-muted small mb-1 fw-semibold text-uppercase" style="font-size:0.7rem; letter-spacing:0.5px;">Published Courses</p>
                                            <h3 class="fw-bold mb-0" style="font-size:2rem; color:#198754;">
                                                <t t-out="published_courses_count"/>
                                            </h3>
                                            <small class="text-muted">Live on platform</small>
                                        </div>
                                        <div class="rounded-circle d-flex align-items-center justify-content-center"
                                             style="width:48px;height:48px;background:rgba(25,135,84,0.15);">
                                            <i class="fa fa-graduation-cap fa-lg" style="color:#198754;"/>
                                        </div>
                                    </div>
                                    <a href="/courses" class="btn btn-success btn-sm mt-2 w-100">View Catalog</a>
                                </div>
                            </div>
                        </div>

                        <!-- Published Events -->
                        <div class="col-sm-6 col-lg-3">
                            <div class="card border-0 shadow-sm h-100"
                                 style="border-radius: var(--impc-border-radius); border-left: 4px solid #0d6efd !important;">
                                <div class="card-body p-3">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <div>
                                            <p class="text-muted small mb-1 fw-semibold text-uppercase" style="font-size:0.7rem; letter-spacing:0.5px;">Published Events</p>
                                            <h3 class="fw-bold mb-0" style="font-size:2rem; color:#0d6efd;">
                                                <t t-out="published_events_count"/>
                                            </h3>
                                            <small class="text-muted">Confirmed &amp; active</small>
                                        </div>
                                        <div class="rounded-circle d-flex align-items-center justify-content-center"
                                             style="width:48px;height:48px;background:rgba(13,110,253,0.15);">
                                            <i class="fa fa-map-marker fa-lg" style="color:#0d6efd;"/>
                                        </div>
                                    </div>
                                    <a href="/event" class="btn btn-primary btn-sm mt-2 w-100">View Events</a>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- ================================================ -->
                    <!-- Stats Widgets Row 2                               -->
                    <!-- ================================================ -->
                    <div class="row g-3 mb-4">

                        <!-- Active Learners -->
                        <div class="col-sm-6 col-lg-3">
                            <div class="card border-0 shadow-sm h-100"
                                 style="border-radius: var(--impc-border-radius); border-left: 4px solid #0dcaf0 !important;">
                                <div class="card-body p-3">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <div>
                                            <p class="text-muted small mb-1 fw-semibold text-uppercase" style="font-size:0.7rem; letter-spacing:0.5px;">Active Learners</p>
                                            <h3 class="fw-bold mb-0" style="font-size:2rem; color:#0dcaf0;">
                                                <t t-out="active_learners_count"/>
                                            </h3>
                                            <small class="text-muted">Currently enrolled</small>
                                        </div>
                                        <div class="rounded-circle d-flex align-items-center justify-content-center"
                                             style="width:48px;height:48px;background:rgba(13,202,240,0.15);">
                                            <i class="fa fa-users fa-lg" style="color:#0dcaf0;"/>
                                        </div>
                                    </div>
                                    <a href="/web#model=res.users&amp;view_type=list" class="btn btn-info btn-sm mt-2 w-100 text-white">Manage Users</a>
                                </div>
                            </div>
                        </div>

                        <!-- Upcoming Events -->
                        <div class="col-sm-6 col-lg-3">
                            <div class="card border-0 shadow-sm h-100"
                                 style="border-radius: var(--impc-border-radius); border-left: 4px solid #6f42c1 !important;">
                                <div class="card-body p-3">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <div>
                                            <p class="text-muted small mb-1 fw-semibold text-uppercase" style="font-size:0.7rem; letter-spacing:0.5px;">Upcoming Events</p>
                                            <h3 class="fw-bold mb-0" style="font-size:2rem; color:#6f42c1;">
                                                <t t-out="upcoming_events_count"/>
                                            </h3>
                                            <small class="text-muted">Scheduled ahead</small>
                                        </div>
                                        <div class="rounded-circle d-flex align-items-center justify-content-center"
                                             style="width:48px;height:48px;background:rgba(111,66,193,0.15);">
                                            <i class="fa fa-clock-o fa-lg" style="color:#6f42c1;"/>
                                        </div>
                                    </div>
                                    <a href="/event" class="btn btn-sm mt-2 w-100" style="background:#6f42c1;color:white;">View Schedule</a>
                                </div>
                            </div>
                        </div>

                        <!-- Certificates Issued -->
                        <div class="col-sm-6 col-lg-3">
                            <div class="card border-0 shadow-sm h-100"
                                 style="border-radius: var(--impc-border-radius); border-left: 4px solid #20c997 !important;">
                                <div class="card-body p-3">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <div>
                                            <p class="text-muted small mb-1 fw-semibold text-uppercase" style="font-size:0.7rem; letter-spacing:0.5px;">Certificates Issued</p>
                                            <h3 class="fw-bold mb-0" style="font-size:2rem; color:#20c997;">
                                                <t t-out="total_certificates"/>
                                            </h3>
                                            <small class="text-muted"><t t-out="pending_certificates"/> pending</small>
                                        </div>
                                        <div class="rounded-circle d-flex align-items-center justify-content-center"
                                             style="width:48px;height:48px;background:rgba(32,201,151,0.15);">
                                            <i class="fa fa-certificate fa-lg" style="color:#20c997;"/>
                                        </div>
                                    </div>
                                    <a href="/web#action=impc_website.action_impc_certificate" class="btn btn-sm mt-2 w-100" style="background:#20c997;color:white;">Manage Certificates</a>
                                </div>
                            </div>
                        </div>

                        <!-- Redeem Codes -->
                        <div class="col-sm-6 col-lg-3">
                            <div class="card border-0 shadow-sm h-100"
                                 style="border-radius: var(--impc-border-radius); border-left: 4px solid #fd7e14 !important;">
                                <div class="card-body p-3">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <div>
                                            <p class="text-muted small mb-1 fw-semibold text-uppercase" style="font-size:0.7rem; letter-spacing:0.5px;">Redeem Codes</p>
                                            <h3 class="fw-bold mb-0" style="font-size:2rem; color:#fd7e14;">
                                                <t t-out="active_codes"/>
                                            </h3>
                                            <small class="text-muted"><t t-out="claimed_codes"/> claimed · <t t-out="expired_codes"/> expired</small>
                                        </div>
                                        <div class="rounded-circle d-flex align-items-center justify-content-center"
                                             style="width:48px;height:48px;background:rgba(253,126,20,0.15);">
                                            <i class="fa fa-ticket fa-lg" style="color:#fd7e14;"/>
                                        </div>
                                    </div>
                                    <a href="/web#action=impc_website.action_impc_redeem_code" class="btn btn-sm mt-2 w-100" style="background:#fd7e14;color:white;">Manage Codes</a>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- ================================================ -->
                    <!-- Main Content: Pending Items + Upcoming Events     -->
                    <!-- ================================================ -->
                    <div class="row g-4">

                        <!-- Pending Course Approvals -->
                        <div class="col-lg-6">
                            <div class="card border-0 shadow-sm" style="border-radius: var(--impc-border-radius);">
                                <div class="card-header bg-white border-bottom d-flex justify-content-between align-items-center py-3" style="border-radius: var(--impc-border-radius) var(--impc-border-radius) 0 0;">
                                    <h6 class="fw-bold mb-0">
                                        <i class="fa fa-book me-2 text-warning"/>Pending Course Approvals
                                        <t t-if="pending_courses_count">
                                            <span class="badge bg-warning text-dark ms-2">
                                                <t t-out="pending_courses_count"/>
                                            </span>
                                        </t>
                                    </h6>
                                    <a href="/management/approvals/courses" class="btn btn-outline-warning btn-sm">View All</a>
                                </div>
                                <div class="card-body p-0">
                                    <t t-if="pending_courses">
                                        <div class="list-group list-group-flush">
                                            <t t-foreach="pending_courses" t-as="course">
                                                <div class="list-group-item list-group-item-action px-3 py-2">
                                                    <div class="d-flex justify-content-between align-items-start">
                                                        <div class="flex-grow-1">
                                                            <p class="mb-0 fw-semibold" style="font-size:0.9rem;">
                                                                <t t-out="course.name"/>
                                                            </p>
                                                            <small class="text-muted">
                                                                By: <t t-out="course.submitted_by.name or 'Unknown'"/>
                                                                · <t t-out="course.learning_mode.title()"/>
                                                            </small>
                                                        </div>
                                                        <span t-attf-class="badge ms-2 #{
                                                            'bg-warning text-dark' if course.approval_state == 'submitted' else
                                                            'bg-info text-white' if course.approval_state == 'under_review' else 'bg-secondary'
                                                        }">
                                                            <t t-out="course.approval_state.replace('_', ' ').title()"/>
                                                        </span>
                                                    </div>
                                                </div>
                                            </t>
                                        </div>
                                    </t>
                                    <t t-else="">
                                        <div class="text-center py-4">
                                            <i class="fa fa-check-circle fa-2x text-success mb-2"/>
                                            <p class="text-muted mb-0">No pending course approvals</p>
                                        </div>
                                    </t>
                                </div>
                            </div>
                        </div>

                        <!-- Pending Event Approvals -->
                        <div class="col-lg-6">
                            <div class="card border-0 shadow-sm" style="border-radius: var(--impc-border-radius);">
                                <div class="card-header bg-white border-bottom d-flex justify-content-between align-items-center py-3" style="border-radius: var(--impc-border-radius) var(--impc-border-radius) 0 0;">
                                    <h6 class="fw-bold mb-0">
                                        <i class="fa fa-calendar me-2 text-danger"/>Pending Event Approvals
                                        <t t-if="pending_events_count">
                                            <span class="badge bg-danger ms-2">
                                                <t t-out="pending_events_count"/>
                                            </span>
                                        </t>
                                    </h6>
                                    <a href="/management/approvals/events" class="btn btn-outline-danger btn-sm">View All</a>
                                </div>
                                <div class="card-body p-0">
                                    <t t-if="pending_events">
                                        <div class="list-group list-group-flush">
                                            <t t-foreach="pending_events" t-as="event">
                                                <div class="list-group-item list-group-item-action px-3 py-2">
                                                    <div class="d-flex justify-content-between align-items-start">
                                                        <div class="flex-grow-1">
                                                            <p class="mb-0 fw-semibold" style="font-size:0.9rem;">
                                                                <t t-out="event.name"/>
                                                            </p>
                                                            <small class="text-muted">
                                                                By: <t t-out="event.impc_submitted_by.name or 'Unknown'"/>
                                                                <t t-if="event.date_begin">
                                                                    · <t t-out="event.date_begin.strftime('%d %b %Y')"/>
                                                                </t>
                                                            </small>
                                                        </div>
                                                        <span t-attf-class="badge ms-2 #{
                                                            'bg-warning text-dark' if event.impc_approval_state == 'submitted' else
                                                            'bg-info text-white' if event.impc_approval_state == 'under_review' else 'bg-secondary'
                                                        }">
                                                            <t t-out="event.impc_approval_state.replace('_', ' ').title()"/>
                                                        </span>
                                                    </div>
                                                </div>
                                            </t>
                                        </div>
                                    </t>
                                    <t t-else="">
                                        <div class="text-center py-4">
                                            <i class="fa fa-check-circle fa-2x text-success mb-2"/>
                                            <p class="text-muted mb-0">No pending event approvals</p>
                                        </div>
                                    </t>
                                </div>
                            </div>
                        </div>

                        <!-- Upcoming Events -->
                        <div class="col-12">
                            <div class="card border-0 shadow-sm" style="border-radius: var(--impc-border-radius);">
                                <div class="card-header bg-white border-bottom py-3" style="border-radius: var(--impc-border-radius) var(--impc-border-radius) 0 0;">
                                    <h6 class="fw-bold mb-0">
                                        <i class="fa fa-clock-o me-2" style="color:#6f42c1;"/>Upcoming Events
                                    </h6>
                                </div>
                                <div class="card-body p-0">
                                    <t t-if="upcoming_events">
                                        <div class="table-responsive">
                                            <table class="table table-hover mb-0">
                                                <thead class="table-light">
                                                    <tr>
                                                        <th class="ps-3" style="font-size:0.8rem; font-weight:600;">Event Name</th>
                                                        <th style="font-size:0.8rem; font-weight:600;">Date</th>
                                                        <th style="font-size:0.8rem; font-weight:600;">Location</th>
                                                        <th style="font-size:0.8rem; font-weight:600;">IMPC Status</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    <t t-foreach="upcoming_events" t-as="evt">
                                                        <tr>
                                                            <td class="ps-3 fw-semibold" style="font-size:0.9rem;">
                                                                <t t-out="evt.name"/>
                                                            </td>
                                                            <td style="font-size:0.85rem;">
                                                                <t t-if="evt.date_begin">
                                                                    <t t-out="evt.date_begin.strftime('%d %b %Y, %H:%M')"/>
                                                                </t>
                                                            </td>
                                                            <td style="font-size:0.85rem;" class="text-muted">
                                                                <t t-out="evt.address_inline or '—'"/>
                                                            </td>
                                                            <td>
                                                                <span t-attf-class="badge #{
                                                                    'bg-success' if evt.impc_approval_state == 'approved' else
                                                                    'bg-warning text-dark' if evt.impc_approval_state == 'submitted' else
                                                                    'bg-info text-white' if evt.impc_approval_state == 'under_review' else
                                                                    'bg-danger' if evt.impc_approval_state == 'rejected' else 'bg-secondary'
                                                                }">
                                                                    <t t-out="evt.impc_approval_state.replace('_', ' ').title()"/>
                                                                </span>
                                                            </td>
                                                        </tr>
                                                    </t>
                                                </tbody>
                                            </table>
                                        </div>
                                    </t>
                                    <t t-else="">
                                        <div class="text-center py-4">
                                            <i class="fa fa-calendar-o fa-2x text-muted mb-2"/>
                                            <p class="text-muted mb-0">No upcoming events scheduled</p>
                                        </div>
                                    </t>
                                </div>
                            </div>
                        </div>

                    </div>
                    <!-- end row -->

                </div>
                <!-- end container -->
            </div>

        </t>
    </template>

</odoo>
