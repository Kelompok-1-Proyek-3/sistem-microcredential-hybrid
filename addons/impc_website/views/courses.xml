<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- IMPC Courses Catalog -->
        <template id="impc_courses" name="IMPC Courses">
            <t t-call="website.layout">
                <div id="wrap">
                    <main>
                        <!-- PAGE HEADER -->
                        <section style="background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%); color: white; padding: 3rem 0;">
                            <div class="container">
                                <h1 style="color: white; margin-bottom: 0.5rem;">Explore Our Courses</h1>
                                <p style="font-size: 1.1rem; opacity: 0.95;">Choose from <t t-text="len(courses)"/> industry-recognized courses</p>
                            </div>
                        </section>

                        <!-- SEARCH AND FILTERS -->
                        <section class="py-4" style="background: var(--gray-50); border-bottom: 1px solid var(--gray-200);">
                            <div class="container">
                                <form method="GET" action="/impc/courses" class="row g-3">
                                    <!-- Search Bar -->
                                    <div class="col-md-4">
                                        <input type="text" name="search" class="form-control form-control-lg" placeholder="Search courses..." t-att-value="search_query or ''"/>
                                    </div>

                                    <!-- Category Filter -->
                                    <div class="col-md-3">
                                        <select name="category" class="form-select form-select-lg">
                                            <option value="">All Categories</option>
                                            <t t-foreach="categories" t-as="cat">
                                                <option t-att-value="cat.id" t-att-selected="str(cat.id) == current_category">
                                                    <t t-text="cat.name"/>
                                                </option>
                                            </t>
                                        </select>
                                    </div>

                                    <!-- Difficulty Filter -->
                                    <div class="col-md-3">
                                        <select name="difficulty" class="form-select form-select-lg">
                                            <option value="">All Levels</option>
                                            <option value="beginner" t-att-selected="current_difficulty == 'beginner'">Beginner</option>
                                            <option value="intermediate" t-att-selected="current_difficulty == 'intermediate'">Intermediate</option>
                                            <option value="advanced" t-att-selected="current_difficulty == 'advanced'">Advanced</option>
                                        </select>
                                    </div>

                                    <!-- Sort Dropdown -->
                                    <div class="col-md-2">
                                        <select name="sort" class="form-select form-select-lg" onchange="this.form.submit();">
                                            <option value="newest" t-att-selected="current_sort == 'newest'">Newest</option>
                                            <option value="popular" t-att-selected="current_sort == 'popular'">Popular</option>
                                            <option value="rating" t-att-selected="current_sort == 'rating'">Highest Rated</option>
                                            <option value="name" t-att-selected="current_sort == 'name'">A-Z</option>
                                        </select>
                                    </div>

                                    <!-- Search Button -->
                                    <div class="col-12">
                                        <button type="submit" class="btn btn-primary w-100">Search Courses</button>
                                    </div>
                                </form>
                            </div>
                        </section>

                        <!-- COURSES GRID -->
                        <section class="py-5">
                            <div class="container">
                                <t t-if="courses">
                                    <div class="row g-4">
                                        <t t-foreach="courses" t-as="course">
                                            <div class="col-lg-4 col-md-6">
                                                <div class="course-card">
                                                    <div class="course-card-image">
                                                        <span class="course-card-badge" t-text="course.category_id.name or 'General'"/>
                                                    </div>
                                                    <div class="course-card-body">
                                                        <h5 class="course-card-title" t-text="course.name"/>
                                                        <span class="course-card-category" t-text="(course.difficulty or 'Beginner').title()"/>
                                                        
                                                        <div class="course-card-rating">
                                                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                                                            <span class="ms-2">4.8</span>
                                                        </div>
                                                        
                                                        <p class="mt-3" style="color: var(--text-light); font-size: 0.9rem; line-height: 1.5;">
                                                            <t t-text="(course.description or 'Learn valuable skills')[:100] + ('...' if len(course.description or '') > 100 else '')"/>
                                                        </p>

                                                        <div style="margin-top: 1rem; padding-top: 1rem; border-top: 1px solid var(--gray-200); font-size: 0.85rem; color: var(--text-light);">
                                                            <t t-if="course.duration">
                                                                <span>⏱ <t t-text="course.duration"/> hours</span><br/>
                                                            </t>
                                                            <t t-if="hasattr(course, 'student_count')">
                                                                <span>👥 <t t-text="course.student_count"/> students</span>
                                                            </t>
                                                        </div>
                                                    </div>
                                                    <div class="course-card-footer">
                                                        <span class="course-card-price">Free</span>
                                                        <a href="#" class="btn btn-primary">Enroll Now</a>
                                                    </div>
                                                </div>
                                            </div>
                                        </t>
                                    </div>
                                </t>
                                <t t-else="">
                                    <div class="alert alert-info text-center py-5">
                                        <h5>No courses found</h5>
                                        <p class="mb-0">Try adjusting your search or filters</p>
                                    </div>
                                </t>
                            </div>
                        </section>
                    </main>
                </div>
            </t>
        </template>
    </data>
</odoo>
