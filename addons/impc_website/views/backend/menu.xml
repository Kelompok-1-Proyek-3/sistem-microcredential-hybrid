<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- IMPC Backend Menu                                            -->
    <!-- Approvals sub-menu is restricted to Odoo Administrators     -->
    <!-- (base.group_system) who act as IMPC platform administrators  -->
    <!-- ============================================================ -->

    <!-- Top-level menu -->
    <menuitem id="menu_impc_root"
              name="IMPC Microcredential"
              web_icon="impc_website,static/description/icon.png"
              sequence="100"
              groups="base.group_user,impc_website.group_impc_teacher,impc_website.group_impc_officer,impc_website.group_impc_manager"/>

    <!-- ======================== -->
    <!-- Approvals (Admin only)   -->
    <!-- ======================== -->
    <menuitem id="menu_impc_approvals"
              name="Approvals"
              parent="menu_impc_root"
              sequence="5"
              groups="base.group_system"/>

    <menuitem id="menu_impc_course_approvals"
              name="Course Approvals"
              parent="menu_impc_approvals"
              action="action_impc_pending_courses"
              sequence="10"
              groups="base.group_system"/>

    <menuitem id="menu_impc_all_courses_approval"
              name="All Submitted Courses"
              parent="menu_impc_approvals"
              action="action_impc_all_courses_approval"
              sequence="20"
              groups="base.group_system"/>

    <menuitem id="menu_impc_event_approvals"
              name="Event Approvals"
              parent="menu_impc_approvals"
              action="action_impc_pending_events"
              sequence="30"
              groups="base.group_system"/>

    <menuitem id="menu_impc_all_events_approval"
              name="All Submitted Events"
              parent="menu_impc_approvals"
              action="action_impc_all_events_approval"
              sequence="40"
              groups="base.group_system"/>

    <!-- ======================== -->
    <!-- Redeem Codes             -->
    <!-- ======================== -->
    <menuitem id="menu_impc_redeem"
              name="Redeem Codes"
              parent="menu_impc_root"
              sequence="10"/>

    <menuitem id="menu_impc_redeem_codes"
              name="Redeem Codes"
              parent="menu_impc_redeem"
              action="action_impc_redeem_code"
              sequence="10"/>

    <menuitem id="menu_impc_redeem_batches"
              name="Batches"
              parent="menu_impc_redeem"
              action="action_impc_redeem_code_batch"
              sequence="20"/>

    <!-- ======================== -->
    <!-- Certificates             -->
    <!-- ======================== -->
    <menuitem id="menu_impc_certificates"
              name="Digital Certificates"
              parent="menu_impc_root"
              action="action_impc_certificate"
              sequence="20"
              groups="base.group_user,impc_website.group_impc_teacher,impc_website.group_impc_officer,impc_website.group_impc_manager"/>

    <!-- ======================== -->
    <!-- Session Attendance       -->
    <!-- ======================== -->
    <menuitem id="menu_impc_attendance"
              name="Session Attendance"
              parent="menu_impc_root"
              action="action_impc_session_attendance"
              sequence="30"
              groups="impc_website.group_impc_officer,impc_website.group_impc_manager"/>

</odoo>
