<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- IMPC Dashboard -->
        <template id="impc_dashboard" name="IMPC Dashboard">
            <t t-call="website.layout">
                <div id="wrap">
                    <main>
                        <!-- PAGE HEADER -->
                        <section style="background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%); color: white; padding: 3rem 0;">
                            <div class="container">
                                <h1 style="color: white; margin-bottom: 0.5rem;">My Learning Dashboard</h1>
                                <p style="font-size: 1.1rem; opacity: 0.95;">Welcome back, <t t-text="user.name"/>!</p>
                            </div>
                        </section>

                        <!-- STATS CARDS -->
                        <section class="py-5">
                            <div class="container">
                                <div class="stats-section">
                                    <div class="stat-card">
                                        <div class="stat-card-number" t-text="total_enrolled"/>
                                        <div class="stat-card-label">Enrolled Courses</div>
                                    </div>
                                    <div class="stat-card">
                                        <div class="stat-card-number" t-text="in_progress"/>
                                        <div class="stat-card-label">In Progress</div>
                                    </div>
                                    <div class="stat-card">
                                        <div class="stat-card-number" t-text="total_completed"/>
                                        <div class="stat-card-label">Completed</div>
                                    </div>
                                    <div class="stat-card">
                                        <div class="stat-card-number" t-text="len(certificates)"/>
                                        <div class="stat-card-label">Certificates Earned</div>
                                    </div>
                                </div>
                            </div>
                        </section>

                        <!-- ENROLLED COURSES SECTION -->
                        <section class="py-5" style="background: var(--bg-light);">
                            <div class="container">
                                <h2 class="section-title">Your Courses</h2>
                                <t t-if="enrolled_courses">
                                    <div class="row g-4">
                                        <t t-foreach="enrolled_courses" t-as="course">
                                            <div class="col-lg-6">
                                                <div style="background: white; border-radius: 0.75rem; overflow: hidden; border: 1px solid var(--gray-200); display: flex; height: 100%;">
                                                    <!-- Course Image -->
                                                    <div style="width: 150px; background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%); display: flex; align-items: center; justify-content: center; color: white; flex-shrink: 0;">
                                                        <div style="font-size: 3rem;">📚</div>
                                                    </div>
                                                    <!-- Course Info -->
                                                    <div style="flex: 1; padding: 1.5rem;">
                                                        <h5 style="font-weight: 700; color: var(--gray-900); margin-bottom: 0.5rem;" t-text="course.name"/>
                                                        <span style="display: inline-block; background: var(--primary); color: white; padding: 0.3rem 0.8rem; border-radius: 0.3rem; font-size: 0.75rem; font-weight: 600; margin-bottom: 1rem;" t-text="(course.difficulty or 'Beginner').title()"/>
                                                        
                                                        <!-- Progress Bar -->
                                                        <div style="margin: 1rem 0;">
                                                            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem;">
                                                                <span style="font-size: 0.85rem; color: var(--text-light);">Progress</span>
                                                                <span style="font-size: 0.85rem; font-weight: 600; color: var(--primary);">65%</span>
                                                            </div>
                                                            <div style="background: var(--gray-200); border-radius: 0.25rem; height: 6px; overflow: hidden;">
                                                                <div style="background: linear-gradient(90deg, var(--primary), var(--secondary)); height: 100%; width: 65%;"></div>
                                                            </div>
                                                        </div>

                                                        <div style="display: flex; gap: 1rem; margin-top: 1rem;">
                                                            <a href="#" class="btn btn-primary" style="padding: 0.5rem 1.5rem; font-size: 0.9rem;">Continue Learning</a>
                                                            <a href="#" class="btn btn-secondary" style="padding: 0.5rem 1.5rem; font-size: 0.9rem;">View Details</a>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </t>
                                    </div>
                                </t>
                                <t t-else="">
                                    <div class="alert alert-info py-4">
                                        <p style="margin-bottom: 0.5rem;">You haven't enrolled in any courses yet.</p>
                                        <a href="/impc/courses" class="btn btn-primary">Browse Courses</a>
                                    </div>
                                </t>
                            </div>
                        </section>

                        <!-- CERTIFICATES SECTION -->
                        <t t-if="certificates">
                            <section class="py-5">
                                <div class="container">
                                    <h2 class="section-title">Your Certificates</h2>
                                    <div class="row g-4">
                                        <t t-foreach="certificates" t-as="cert">
                                            <div class="col-lg-4 col-md-6">
                                                <div style="background: white; border: 2px solid var(--primary); border-radius: 0.75rem; padding: 2rem; text-align: center; transition: all 0.3s ease;">
                                                    <div style="font-size: 3rem; margin-bottom: 1rem;">🏆</div>
                                                    <h5 style="font-weight: 700; color: var(--gray-900); margin-bottom: 0.5rem;" t-text="cert.course_id.name"/>
                                                    <p style="color: var(--text-light); font-size: 0.9rem; margin-bottom: 1rem;">Certificate of Completion</p>
                                                    <p style="font-size: 0.85rem; color: var(--text-light); margin-bottom: 1.5rem;">
                                                        Earned on <t t-text="cert.create_date.strftime('%B %d, %Y') if cert.create_date else 'Unknown date'"/>
                                                    </p>
                                                    <div style="display: flex; gap: 0.5rem;">
                                                        <a href="#" class="btn btn-primary" style="flex: 1; padding: 0.5rem 1rem; font-size: 0.9rem;">Download</a>
                                                        <a href="#" class="btn btn-secondary" style="flex: 1; padding: 0.5rem 1rem; font-size: 0.9rem;">Share</a>
                                                    </div>
                                                </div>
                                            </div>
                                        </t>
                                    </div>
                                </div>
                            </section>
                        </t>

                        <!-- RECOMMENDED COURSES SECTION -->
                        <section class="py-5" style="background: var(--bg-light);">
                            <div class="container">
                                <h2 class="section-title">Recommended For You</h2>
                                <p class="section-subtitle">Based on your learning path</p>
                                <div class="row g-4">
                                    <div class="col-lg-4">
                                        <div class="course-card">
                                            <div class="course-card-image">
                                                <span class="course-card-badge">Recommended</span>
                                            </div>
                                            <div class="course-card-body">
                                                <h5 class="course-card-title">Advanced Python</h5>
                                                <span class="course-card-category">Intermediate</span>
                                                <div class="course-card-rating">
                                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                                                    <span class="ms-2">4.9 (187 reviews)</span>
                                                </div>
                                            </div>
                                            <div class="course-card-footer">
                                                <span class="course-card-price">Free</span>
                                                <a href="/impc/courses" class="btn btn-primary">Enroll</a>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="text-center mt-4">
                                    <a href="/impc/courses" class="btn btn-primary">Explore More Courses</a>
                                </div>
                            </div>
                        </section>
                    </main>
                </div>
            </t>
        </template>
    </data>
</odoo>
