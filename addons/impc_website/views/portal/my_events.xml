<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- IMPC My Events Portal Page                                   -->
    <!-- ============================================================ -->

    <template id="portal_my_events" name="IMPC My Events">
        <t t-call="website.layout">
            <t t-set="title">My Events - IMPC</t>

            <div class="impc-my-events py-4">
                <div class="container">

                    <!-- Header -->
                    <div class="mb-4">
                        <h3 class="fw-bold mb-1">Upcoming Events</h3>
                        <p class="text-muted mb-0">
                            Jadwal sesi offline/hybrid untuk kursus Anda
                        </p>
                    </div>

                    <!-- Events List -->
                    <t t-if="events_data">
                        <div class="row g-4">
                            <t t-foreach="events_data" t-as="ev">
                                <div class="col-md-6">
                                    <div class="card border-0 shadow-sm rounded-3 h-100">
                                        <div class="card-body p-4">
                                            <!-- Event Header -->
                                            <div class="d-flex align-items-start mb-3">
                                                <div class="bg-info bg-opacity-10 rounded-3 p-3 me-3 text-center"
                                                     style="min-width: 60px;">
                                                    <t t-if="ev['event'].date_begin">
                                                        <div class="fw-bold text-info" t-out="ev['event'].date_begin.strftime('%d')"/>
                                                        <small class="text-muted" t-out="ev['event'].date_begin.strftime('%b')"/>
                                                    </t>
                                                </div>
                                                <div class="flex-grow-1">
                                                    <h6 class="fw-bold mb-1" t-out="ev['event'].name"/>
                                                    <small class="text-muted d-block">
                                                        <i class="fa fa-book me-1"></i>
                                                        <t t-out="ev['enrollment'].channel_id.name"/>
                                                    </small>
                                                </div>
                                            </div>

                                            <!-- Event Details -->
                                            <div class="small text-muted mb-3">
                                                <div class="mb-1" t-if="ev['event'].date_begin">
                                                    <i class="fa fa-clock-o me-2"></i>
                                                    <t t-out="ev['event'].date_begin" t-options="{'widget': 'datetime'}"/>
                                                </div>
                                                <div class="mb-1" t-if="ev['event'].address_inline">
                                                    <i class="fa fa-map-marker me-2"></i>
                                                    <t t-out="ev['event'].address_inline"/>
                                                </div>
                                            </div>

                                            <!-- Attendance Status -->
                                            <div class="d-flex align-items-center justify-content-between p-2 rounded"
                                                  t-attf-class="bg-#{ev['attendance_status'] == 'hadir' and 'success' or ev['attendance_status'] == 'tidak_hadir' and 'danger' or 'warning'} bg-opacity-10">
                                                <span class="small fw-bold"
                                                      t-attf-class="text-#{ev['attendance_status'] == 'hadir' and 'success' or ev['attendance_status'] == 'tidak_hadir' and 'danger' or 'warning'}">
                                                    <i t-attf-class="fa me-1 #{ev['attendance_status'] == 'hadir' and 'fa-check-circle' or ev['attendance_status'] == 'tidak_hadir' and 'fa-times-circle' or 'fa-clock-o'}"></i>
                                                    <t t-if="ev['attendance_status'] == 'hadir'">Hadir (Attended)</t>
                                                    <t t-elif="ev['attendance_status'] == 'tidak_hadir'">Tidak Hadir</t>
                                                    <t t-else="">Pending</t>
                                                </span>
                                                <t t-if="ev['is_registered']">
                                                    <span class="badge bg-success bg-opacity-75 small">Registered</span>
                                                </t>
                                            </div>

                                            <!-- Actions -->
                                            <div class="mt-3">
                                                <t t-if="ev['is_registered'] and ev['registration']">
                                                    <a t-attf-href="/my/events/#{ev['registration'].id}"
                                                       class="btn btn-outline-info btn-sm w-100">
                                                        <i class="fa fa-ticket me-1"></i>Lihat E-Ticket
                                                    </a>
                                                </t>
                                                <t t-if="not ev['is_registered']">
                                                    <a t-attf-href="/event/#{slug(ev['event'])}/register"
                                                       class="btn btn-info btn-sm w-100">
                                                        <i class="fa fa-plus me-1"></i>Daftar Sesi
                                                    </a>
                                                </t>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </t>
                        </div>
                    </t>

                    <!-- Empty State -->
                    <t t-if="not events_data">
                        <div class="text-center py-5">
                            <div class="bg-light rounded-circle d-inline-flex align-items-center justify-content-center mb-3"
                                 style="width: 100px; height: 100px;">
                                <i class="fa fa-calendar fa-3x text-muted"></i>
                            </div>
                            <h5 class="text-muted">Tidak ada sesi tatap muka</h5>
                            <p class="text-muted">
                                Anda belum terdaftar di kursus hybrid atau offline yang memiliki sesi tatap muka.
                            </p>
                            <a href="/courses?mode=hybrid" class="btn btn-primary">Lihat Kursus Hybrid</a>
                        </div>
                    </t>

                </div>
            </div>
        </t>
    </template>

</odoo>
