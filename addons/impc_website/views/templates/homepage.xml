<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- IMPC Homepage                                                -->
    <!-- ============================================================ -->

    <template id="homepage" name="IMPC Homepage">
        <t t-call="website.layout">
            <t t-set="title">IMPC - Indonesia Microcredential Platform Center</t>

            <div class="impc-homepage">

                <!-- ============================================================ -->
                <!-- AUTH-AWARE CONTENT: Guest vs Logged-in User                  -->
                <!-- ============================================================ -->

                <t t-if="not is_authenticated">
                    <!-- ========== GUEST: HERO SECTION ========== -->
                    <section class="impc-hero position-relative overflow-hidden">
                        <div class="impc-hero-bg"></div>
                        <div class="container position-relative py-5">
                            <div class="row align-items-center min-vh-75">
                                <div class="col-lg-6">
                                    <span class="badge bg-primary bg-opacity-10 text-primary px-3 py-2 mb-3 rounded-pill">
                                        Platform Microcredential #1 di Indonesia
                                    </span>
                                    <h1 class="display-4 fw-bold text-dark mb-3">
                                        Tingkatkan <span class="text-primary">Kompetensi</span> Anda
                                        dengan Sertifikasi Mikro
                                    </h1>
                                    <p class="lead text-muted mb-4">
                                        Pelajari keterampilan yang dibutuhkan industri melalui kursus
                                        terstruktur dengan sertifikat digital yang dapat diverifikasi.
                                        Belajar online, offline, atau hybrid sesuai kebutuhan Anda.
                                    </p>
                                    <div class="d-flex flex-wrap gap-3">
                                        <a href="/courses" class="btn btn-primary btn-lg px-4">
                                            <i class="fa fa-book me-2"></i>Jelajahi Kursus
                                        </a>
                                        <a href="/corporate-training" class="btn btn-outline-dark btn-lg px-4">
                                            <i class="fa fa-building me-2"></i>Corporate Training
                                        </a>
                                    </div>
                                    <div class="mt-4 pt-3 d-flex align-items-center gap-4 text-muted small">
                                        <span><i class="fa fa-check-circle text-success me-1"></i> Sertifikat Terverifikasi</span>
                                        <span><i class="fa fa-check-circle text-success me-1"></i> Diakui Industri</span>
                                        <span><i class="fa fa-check-circle text-success me-1"></i> Hybrid Learning</span>
                                    </div>
                                </div>
                                <div class="col-lg-6 d-none d-lg-block text-center">
                                    <div class="impc-hero-illustration p-4">
                                        <div class="card shadow-lg border-0 rounded-4 p-4">
                                            <div class="d-flex align-items-center mb-3">
                                                <div class="bg-primary bg-opacity-10 rounded-circle p-3 me-3">
                                                    <i class="fa fa-graduation-cap fa-2x text-primary"></i>
                                                </div>
                                                <div>
                                                    <h6 class="mb-0">Learning in Progress</h6>
                                                    <small class="text-muted">Web Development Fundamentals</small>
                                                </div>
                                            </div>
                                            <div class="progress mb-2" style="height: 8px;">
                                                <div class="progress-bar bg-primary" style="width: 72%"></div>
                                            </div>
                                            <small class="text-muted">72% Complete</small>
                                            <hr/>
                                            <div class="d-flex justify-content-between text-center">
                                                <div>
                                                    <h5 class="text-primary mb-0">12</h5>
                                                    <small class="text-muted">Modules</small>
                                                </div>
                                                <div>
                                                    <h5 class="text-success mb-0">3</h5>
                                                    <small class="text-muted">Certificates</small>
                                                </div>
                                                <div>
                                                    <h5 class="text-warning mb-0">48h</h5>
                                                    <small class="text-muted">Learning</small>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </section>
                </t>

                <t t-if="is_authenticated">
                    <!-- ========== LOGGED-IN USER: DASHBOARD WELCOME ========== -->
                    <section class="impc-auth-hero bg-primary text-white py-5">
                        <div class="container">
                            <div class="row align-items-center">
                                <div class="col-lg-8">
                                    <h2 class="fw-bold mb-2">
                                        Selamat Datang Kembali, <t t-out="request.env.user.name"/>!
                                    </h2>
                                    <p class="opacity-75 mb-0">
                                        Lanjutkan perjalanan belajar Anda. Konsistensi adalah kunci keberhasilan.
                                    </p>
                                </div>
                                <div class="col-lg-4 d-none d-lg-block text-end">
                                    <i class="fa fa-graduation-cap fa-5x opacity-25"></i>
                                </div>
                            </div>
                        </div>
                    </section>

                    <!-- ========== LOGGED-IN USER: STATS CARDS ========== -->
                    <section class="py-4">
                        <div class="container">
                            <div class="row g-3">
                                <div class="col-md-4">
                                    <div class="card border-0 shadow-sm rounded-3 h-100">
                                        <div class="card-body d-flex align-items-center p-3">
                                            <div class="bg-primary bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center me-3"
                                                 style="width: 50px; height: 50px;">
                                                <i class="fa fa-book fa-lg text-primary"></i>
                                            </div>
                                            <div>
                                                <h4 class="fw-bold mb-0" t-out="total_in_progress"/>
                                                <small class="text-muted">In Progress</small>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="card border-0 shadow-sm rounded-3 h-100">
                                        <div class="card-body d-flex align-items-center p-3">
                                            <div class="bg-success bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center me-3"
                                                 style="width: 50px; height: 50px;">
                                                <i class="fa fa-check-circle fa-lg text-success"></i>
                                            </div>
                                            <div>
                                                <h4 class="fw-bold mb-0" t-out="total_completed"/>
                                                <small class="text-muted">Completed</small>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="card border-0 shadow-sm rounded-3 h-100">
                                        <div class="card-body d-flex align-items-center p-3">
                                            <div class="bg-warning bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center me-3"
                                                 style="width: 50px; height: 50px;">
                                                <i class="fa fa-certificate fa-lg text-warning"></i>
                                            </div>
                                            <div>
                                                <h4 class="fw-bold mb-0" t-out="certificates"/>
                                                <small class="text-muted">Certificates</small>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </section>

                    <!-- ========== LOGGED-IN USER: QUICK ACTIONS ========== -->
                    <section class="pb-4">
                        <div class="container">
                            <div class="row g-3">
                                <div class="col-lg-8">
                                    <!-- Continue Learning -->
                                    <t t-if="continue_course">
                                        <div class="card border-0 shadow-sm rounded-3 mb-3">
                                            <div class="card-header bg-white border-0 pt-3 px-4">
                                                <h5 class="fw-bold mb-0">
                                                    <i class="fa fa-play-circle text-primary me-2"></i>Lanjutkan Belajar
                                                </h5>
                                            </div>
                                            <div class="card-body px-4 pb-4">
                                                <div class="d-flex align-items-center">
                                                    <div class="flex-shrink-0 me-3">
                                                        <t t-if="continue_course.channel_id.image_512">
                                                            <img t-attf-src="/web/image/slide.channel/#{continue_course.channel_id.id}/image_512"
                                                                 class="rounded-3" style="width: 80px; height: 80px; object-fit: cover;"
                                                                 t-att-alt="continue_course.channel_id.name"/>
                                                        </t>
                                                        <t t-else="">
                                                            <div class="bg-primary bg-opacity-10 rounded-3 d-flex align-items-center justify-content-center"
                                                                 style="width: 80px; height: 80px;">
                                                                <i class="fa fa-book fa-2x text-primary"></i>
                                                            </div>
                                                        </t>
                                                    </div>
                                                    <div class="flex-grow-1">
                                                        <h6 class="fw-bold mb-1" t-out="continue_course.channel_id.name"/>
                                                        <div class="d-flex justify-content-between small mb-1">
                                                            <span class="text-muted">Progress</span>
                                                            <span class="fw-bold"><t t-out="continue_course.completion"/>%</span>
                                                        </div>
                                                        <div class="progress" style="height: 8px;">
                                                            <div class="progress-bar bg-primary"
                                                                 t-attf-style="width: #{continue_course.completion}%"></div>
                                                        </div>
                                                    </div>
                                                    <div class="ms-3">
                                                        <a t-attf-href="/slides/#{slug(continue_course.channel_id)}"
                                                           class="btn btn-primary btn-sm">
                                                            <i class="fa fa-play"></i>
                                                        </a>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </t>

                                    <!-- Enrolled Courses Summary -->
                                    <div class="card border-0 shadow-sm rounded-3">
                                        <div class="card-header bg-white border-0 pt-3 px-4 d-flex justify-content-between align-items-center">
                                            <h5 class="fw-bold mb-0">
                                                <i class="fa fa-book text-primary me-2"></i>Kursus Saya
                                            </h5>
                                            <a href="/my-learning/courses" class="btn btn-outline-primary btn-sm">
                                                Lihat Semua
                                            </a>
                                        </div>
                                        <div class="card-body px-4 pb-4">
                                            <t t-if="enrollments">
                                                <t t-foreach="enrollments[:5]" t-as="enrollment">
                                                    <div class="d-flex align-items-center py-3 border-bottom">
                                                        <div class="flex-shrink-0 me-3">
                                                            <t t-if="enrollment.channel_id.image_512">
                                                                <img t-attf-src="/web/image/slide.channel/#{enrollment.channel_id.id}/image_512"
                                                                     class="rounded" style="width: 50px; height: 50px; object-fit: cover;"/>
                                                            </t>
                                                            <t t-else="">
                                                                <div class="bg-light rounded d-flex align-items-center justify-content-center"
                                                                     style="width: 50px; height: 50px;">
                                                                    <i class="fa fa-book text-muted"></i>
                                                                </div>
                                                            </t>
                                                        </div>
                                                        <div class="flex-grow-1">
                                                            <h6 class="mb-1 small fw-bold" t-out="enrollment.channel_id.name"/>
                                                            <div class="progress" style="height: 5px;">
                                                                <div class="progress-bar"
                                                                     t-attf-class="bg-#{enrollment.member_status == 'completed' and 'success' or 'primary'}"
                                                                     t-attf-style="width: #{enrollment.completion}%"></div>
                                                            </div>
                                                        </div>
                                                        <div class="ms-3 text-end">
                                                            <span t-attf-class="badge bg-#{enrollment.member_status == 'completed' and 'success' or enrollment.member_status == 'ongoing' and 'primary' or 'secondary'} bg-opacity-10 text-#{enrollment.member_status == 'completed' and 'success' or enrollment.member_status == 'ongoing' and 'primary' or 'secondary'}">
                                                                <t t-out="enrollment.completion"/>%
                                                            </span>
                                                        </div>
                                                    </div>
                                                </t>
                                            </t>
                                            <t t-if="not enrollments">
                                                <div class="text-center py-4">
                                                    <i class="fa fa-book fa-2x text-muted mb-2"></i>
                                                    <p class="text-muted mb-2">Belum ada kursus yang diikuti.</p>
                                                    <a href="/courses" class="btn btn-primary btn-sm">Jelajahi Kursus</a>
                                                </div>
                                            </t>
                                        </div>
                                    </div>
                                </div>

                                <!-- Sidebar Quick Actions -->
                                <div class="col-lg-4">
                                    <div class="card border-0 shadow-sm rounded-3 mb-3">
                                        <div class="card-body p-3">
                                            <h6 class="fw-bold mb-3">Quick Actions</h6>
                                            <div class="d-grid gap-2">
                                                <a href="/my-learning/redeem" class="btn btn-outline-success btn-sm text-start">
                                                    <i class="fa fa-ticket me-2"></i>Redeem Voucher
                                                </a>
                                                <a href="/courses" class="btn btn-outline-primary btn-sm text-start">
                                                    <i class="fa fa-search me-2"></i>Browse Courses
                                                </a>
                                                <a href="/my-learning/certificates" class="btn btn-outline-warning btn-sm text-start">
                                                    <i class="fa fa-certificate me-2"></i>My Certificates
                                                </a>
                                                <a href="/my-learning/events" class="btn btn-outline-info btn-sm text-start">
                                                    <i class="fa fa-calendar me-2"></i>My Events
                                                </a>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Upcoming Events -->
                                    <t t-if="continue_course and continue_course.channel_id.learning_mode in ('hybrid', 'offline') and continue_course.channel_id.event_id">
                                        <div class="card border-0 shadow-sm rounded-3">
                                            <div class="card-body p-3">
                                                <h6 class="fw-bold mb-3">
                                                    <i class="fa fa-calendar text-info me-2"></i>Next Session
                                                </h6>
                                                <div class="d-flex align-items-center">
                                                    <div class="bg-info bg-opacity-10 rounded p-2 me-2">
                                                        <i class="fa fa-map-marker text-info small"></i>
                                                    </div>
                                                    <div>
                                                        <small class="fw-bold d-block" t-out="continue_course.channel_id.event_id.name"/>
                                                        <small class="text-muted" t-out="continue_course.channel_id.event_date_begin" t-options="{'widget': 'date'}"/>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </t>
                                </div>
                            </div>
                        </div>
                    </section>
                </t>

                <!-- ========== STATS SECTION (public, shown to all) ========== -->
                <section class="impc-stats bg-primary text-white py-4">
                    <div class="container">
                        <div class="row text-center g-4">
                            <div class="col-6 col-md-3">
                                <h3 class="fw-bold mb-0" t-out="total_students or 0"/>
                                <small class="opacity-75">Students Enrolled</small>
                            </div>
                            <div class="col-6 col-md-3">
                                <h3 class="fw-bold mb-0" t-out="total_courses or 0"/>
                                <small class="opacity-75">Courses Available</small>
                            </div>
                            <div class="col-6 col-md-3">
                                <h3 class="fw-bold mb-0" t-out="total_certificates or 0"/>
                                <small class="opacity-75">Certificates Issued</small>
                            </div>
                            <div class="col-6 col-md-3">
                                <h3 class="fw-bold mb-0">50+</h3>
                                <small class="opacity-75">Corporate Partners</small>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- ========== FEATURED COURSES (shown to all) ========== -->
                <section class="impc-featured py-5">
                    <div class="container">
                        <div class="text-center mb-5">
                            <h2 class="fw-bold">Kursus Unggulan</h2>
                            <p class="text-muted">Pilihan kursus terbaik untuk memulai perjalanan belajar Anda</p>
                        </div>
                        <div class="row g-4">
                            <t t-foreach="featured_courses" t-as="course">
                                <div class="col-lg-4 col-md-6">
                                    <div class="card impc-course-card h-100 border-0 shadow-sm rounded-3 overflow-hidden">
                                        <div class="impc-course-card-img position-relative">
                                            <t t-if="course.image_512">
                                                <img t-attf-src="/web/image/slide.channel/#{course.id}/image_512"
                                                     class="card-img-top" style="height: 180px; object-fit: cover;"
                                                     t-att-alt="course.name"/>
                                            </t>
                                            <t t-else="">
                                                <div class="bg-primary bg-opacity-10 d-flex align-items-center justify-content-center"
                                                     style="height: 180px;">
                                                    <i class="fa fa-book fa-3x text-primary opacity-50"></i>
                                                </div>
                                            </t>
                                            <span class="badge position-absolute top-0 end-0 m-2"
                                                  t-attf-class="bg-#{course.learning_mode == 'online' and 'success' or course.learning_mode == 'hybrid' and 'warning' or 'info'}">
                                                <t t-out="course.learning_mode.upper() if course.learning_mode else 'ONLINE'"/>
                                            </span>
                                            <!-- Enrolled badge for authenticated users -->
                                            <t t-if="is_authenticated and course.id in enrolled_ids">
                                                <span class="badge bg-success position-absolute top-0 start-0 m-2">
                                                    <i class="fa fa-check me-1"></i>Enrolled
                                                </span>
                                            </t>
                                        </div>
                                        <div class="card-body d-flex flex-column">
                                            <div class="mb-2">
                                                <t t-foreach="course.tag_ids[:2]" t-as="tag">
                                                    <span class="badge bg-light text-dark me-1 small" t-out="tag.name"/>
                                                </t>
                                            </div>
                                            <h6 class="card-title fw-bold">
                                                <a t-attf-href="/courses/#{slug(course)}"
                                                   class="text-dark text-decoration-none stretched-link">
                                                    <t t-out="course.name"/>
                                                </a>
                                            </h6>
                                            <p class="card-text text-muted small flex-grow-1">
                                                <t t-out="(course.short_description or course.description_short or '')[:120]"/>
                                                <t t-if="len(course.short_description or course.description_short or '') > 120">...</t>
                                            </p>
                                            <div class="d-flex justify-content-between align-items-center mt-auto pt-2 border-top">
                                                <div class="small text-muted">
                                                    <i class="fa fa-signal me-1"></i>
                                                    <t t-out="(course.difficulty_level or 'beginner').capitalize()"/>
                                                </div>
                                                <div class="small text-muted">
                                                    <i class="fa fa-clock-o me-1"></i>
                                                    <t t-out="int(course.estimated_duration or 0)"/> hours
                                                </div>
                                                <div class="small text-muted">
                                                    <i class="fa fa-users me-1"></i>
                                                    <t t-out="course.enrolled_count or 0"/>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </t>
                        </div>
                        <div class="text-center mt-5">
                            <a href="/courses" class="btn btn-outline-primary btn-lg px-5">
                                Lihat Semua Kursus <i class="fa fa-arrow-right ms-2"></i>
                            </a>
                        </div>
                    </div>
                </section>

                <!-- ========== HOW IT WORKS (shown to all) ========== -->
                <section class="impc-how-it-works bg-light py-5">
                    <div class="container">
                        <div class="text-center mb-5">
                            <h2 class="fw-bold">Bagaimana Cara Kerjanya?</h2>
                            <p class="text-muted">Mulai perjalanan belajar Anda dalam 4 langkah mudah</p>
                        </div>
                        <div class="row g-4">
                            <div class="col-md-3 text-center">
                                <div class="bg-primary bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center mb-3"
                                     style="width: 80px; height: 80px;">
                                    <i class="fa fa-user-plus fa-2x text-primary"></i>
                                </div>
                                <h6 class="fw-bold">1. Daftar</h6>
                                <p class="text-muted small">Buat akun gratis dan lengkapi profil Anda</p>
                            </div>
                            <div class="col-md-3 text-center">
                                <div class="bg-success bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center mb-3"
                                     style="width: 80px; height: 80px;">
                                    <i class="fa fa-search fa-2x text-success"></i>
                                </div>
                                <h6 class="fw-bold">2. Pilih Kursus</h6>
                                <p class="text-muted small">Jelajahi katalog dan pilih kursus sesuai kebutuhan</p>
                            </div>
                            <div class="col-md-3 text-center">
                                <div class="bg-warning bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center mb-3"
                                     style="width: 80px; height: 80px;">
                                    <i class="fa fa-play-circle fa-2x text-warning"></i>
                                </div>
                                <h6 class="fw-bold">3. Belajar</h6>
                                <p class="text-muted small">Akses materi, ikuti sesi, dan selesaikan ujian</p>
                            </div>
                            <div class="col-md-3 text-center">
                                <div class="bg-info bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center mb-3"
                                     style="width: 80px; height: 80px;">
                                    <i class="fa fa-certificate fa-2x text-info"></i>
                                </div>
                                <h6 class="fw-bold">4. Sertifikasi</h6>
                                <p class="text-muted small">Dapatkan sertifikat digital yang dapat diverifikasi</p>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- ========== LEARNING MODES (shown to all) ========== -->
                <section class="impc-modes py-5">
                    <div class="container">
                        <div class="text-center mb-5">
                            <h2 class="fw-bold">Mode Pembelajaran Fleksibel</h2>
                            <p class="text-muted">Pilih cara belajar yang paling sesuai dengan gaya Anda</p>
                        </div>
                        <div class="row g-4">
                            <div class="col-md-4">
                                <div class="card border-0 shadow-sm h-100 text-center p-4 rounded-3">
                                    <div class="bg-success bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center mx-auto mb-3"
                                         style="width: 70px; height: 70px;">
                                        <i class="fa fa-laptop fa-2x text-success"></i>
                                    </div>
                                    <h5 class="fw-bold">Online</h5>
                                    <p class="text-muted small">
                                        Belajar kapan saja, di mana saja.
                                    </p>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="card border-0 shadow-sm h-100 text-center p-4 rounded-3">
                                    <div class="bg-warning bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center mx-auto mb-3"
                                         style="width: 70px; height: 70px;">
                                        <i class="fa fa-exchange fa-2x text-warning"></i>
                                    </div>
                                    <h5 class="fw-bold">Hybrid</h5>
                                    <p class="text-muted small">
                                        Kombinasi online dan tatap muka.
                                    </p>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="card border-0 shadow-sm h-100 text-center p-4 rounded-3">
                                    <div class="bg-info bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center mx-auto mb-3"
                                         style="width: 70px; height: 70px;">
                                        <i class="fa fa-users fa-2x text-info"></i>
                                    </div>
                                    <h5 class="fw-bold">Offline</h5>
                                    <p class="text-muted small">
                                        Pembelajaran tatap muka penuh.
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- ========== CATEGORIES (shown to all) ========== -->
                <t t-if="categories">
                    <section class="impc-categories bg-light py-5">
                        <div class="container">
                            <div class="text-center mb-5">
                                <h2 class="fw-bold">Kategori Kursus</h2>
                                <p class="text-muted">Temukan kursus berdasarkan bidang keahlian</p>
                            </div>
                            <div class="row g-3 justify-content-center">
                                <t t-foreach="categories" t-as="cat">
                                    <div class="col-6 col-md-3">
                                        <a t-attf-href="/courses?category=#{cat.id}"
                                           class="card border-0 shadow-sm text-center p-3 rounded-3 text-decoration-none impc-category-card">
                                            <div class="bg-primary bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center mx-auto mb-2"
                                                 style="width: 50px; height: 50px;">
                                                <i class="fa fa-folder-open text-primary"></i>
                                            </div>
                                            <h6 class="mb-0 text-dark small fw-bold" t-out="cat.name"/>
                                        </a>
                                    </div>
                                </t>
                            </div>
                        </div>
                    </section>
                </t>

                <!-- ========== CTA SECTION (shown to all, but adjusted for auth) ========== -->
                <section class="impc-cta py-5">
                    <div class="container">
                        <div class="bg-primary rounded-4 p-5 text-center text-white">
                            <h2 class="fw-bold mb-3">
                                <t t-if="not is_authenticated">Siap Meningkatkan Kompetensi Anda?</t>
                                <t t-if="is_authenticated">Terus Kembangkan Diri Anda</t>
                            </h2>
                            <p class="mb-4 opacity-75">
                                <t t-if="not is_authenticated">
                                    Bergabung dengan ribuan profesional yang telah meningkatkan karir mereka
                                    melalui sertifikasi mikro IMPC.
                                </t>
                                <t t-if="is_authenticated">
                                    Jelajahi lebih banyak kursus dan dapatkan sertifikasi baru untuk mengembangkan karir Anda.
                                </t>
                            </p>
                            <div class="d-flex flex-wrap justify-content-center gap-3">
                                <t t-if="not is_authenticated">
                                    <a href="/web/signup" class="btn btn-light btn-lg px-4 fw-bold">
                                        Daftar Gratis
                                    </a>
                                </t>
                                <t t-if="is_authenticated">
                                    <a href="/courses" class="btn btn-light btn-lg px-4 fw-bold">
                                        Jelajahi Kursus
                                    </a>
                                </t>
                                <a href="/corporate-training" class="btn btn-outline-light btn-lg px-4">
                                    Program Corporate
                                </a>
                            </div>
                        </div>
                    </div>
                </section>

            </div>
        </t>
    </template>

</odoo>
