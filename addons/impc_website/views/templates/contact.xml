<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- IMPC Contact Page                                            -->
    <!-- ============================================================ -->

    <template id="contact_page" name="IMPC Contact">
        <t t-call="website.layout">
            <t t-set="title">Contact - IMPC Microcredential</t>

            <div class="impc-contact-page py-5">
                <div class="container">
                    <div class="row g-4">
                        <div class="col-lg-5">
                            <h2 class="fw-bold mb-3">Contact Us</h2>
                            <p class="text-muted mb-4">
                                Hubungi tim IMPC untuk informasi program pelatihan, kerja sama,
                                dan akses tim.
                            </p>

                            <div class="card border-0 shadow-sm rounded-3">
                                <div class="card-body p-4">
                                    <h6 class="fw-bold mb-3">Company Information</h6>
                                    <ul class="list-unstyled text-muted mb-0">
                                        <li class="mb-2">
                                            <i class="fa fa-map-marker me-2"></i>Jakarta, Indonesia
                                        </li>
                                        <li class="mb-2">
                                            <i class="fa fa-envelope me-2"></i>info@impc.id
                                        </li>
                                        <li class="mb-0">
                                            <i class="fa fa-phone me-2"></i>+62 21 1234 5678
                                        </li>
                                    </ul>
                                </div>
                            </div>
                        </div>

                        <div class="col-lg-7">
                            <div class="card border-0 shadow-sm rounded-3">
                                <div class="card-body p-4">
                                    <h5 class="fw-bold mb-3">Send Us a Message</h5>
                                    <form class="o_website_form" method="post" data-model_name="crm.lead" data-success-page="/contact">
                                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                        <input type="hidden" name="name" value="IMPC Contact Inquiry"/>
                                        <t t-if="inquiry == 'team_access'">
                                            <input type="hidden" name="inquiry_type" value="team_access"/>
                                        </t>

                                        <div class="row g-3">
                                            <div class="col-md-6">
                                                <label class="form-label fw-bold small">Full Name</label>
                                                <input type="text" name="contact_name" class="form-control" required="required"/>
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label fw-bold small">Email</label>
                                                <input type="email" name="email_from" class="form-control" required="required"/>
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label fw-bold small">Phone Number</label>
                                                <input type="tel" name="phone" class="form-control" required="required"/>
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label fw-bold small">Company / Organization</label>
                                                <input type="text" name="partner_name" class="form-control" required="required"/>
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label fw-bold small">Job Title (Optional)</label>
                                                <input type="text" name="job_title" class="form-control"/>
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label fw-bold small">Number of Participants (Optional)</label>
                                                <input type="number" name="participant_count" class="form-control" min="1"/>
                                            </div>
                                            <div class="col-12">
                                                <label class="form-label fw-bold small">Message</label>
                                                <textarea name="description" class="form-control" rows="4" required="required"></textarea>
                                            </div>
                                        </div>

                                        <div class="d-flex justify-content-end mt-4">
                                            <button type="submit" class="btn btn-primary px-4">
                                                <i class="fa fa-paper-plane me-2"></i>Send Message
                                            </button>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>

</odoo>
