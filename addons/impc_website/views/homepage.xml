<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- IMPC Homepage -->
        <template id="impc_homepage" name="IMPC Homepage">
            <t t-call="website.layout">
                <div id="wrap">
                    <main>
                        <!-- HERO SECTION -->
                        <section class="hero-section">
                            <div class="container">
                                <h1>Master In-Demand Skills</h1>
                                <p class="lead">Earn industry-recognized microcredentials from IMPC</p>
                                <p class="subtitle">Learn at your own pace, on your own schedule</p>
                                <div class="hero-cta">
                                    <a href="/impc/courses" class="btn btn-primary btn-lg">Explore Courses</a>
                                    <button class="btn btn-outline-light btn-lg" onclick="document.getElementById('features').scrollIntoView({behavior: 'smooth'})">Learn More</button>
                                </div>
                            </div>
                        </section>

                        <!-- STATS SECTION -->
                        <section class="py-5">
                            <div class="container">
                                <div class="stats-section">
                                    <div class="stat-card">
                                        <div class="stat-card-number" t-text="total_courses or 0"/>
                                        <div class="stat-card-label">Courses Available</div>
                                    </div>
                                    <div class="stat-card">
                                        <div class="stat-card-number" t-text="total_students or 0"/>
                                        <div class="stat-card-label">Active Students</div>
                                    </div>
                                    <div class="stat-card">
                                        <div class="stat-card-number">100%</div>
                                        <div class="stat-card-label">Industry-Recognized</div>
                                    </div>
                                    <div class="stat-card">
                                        <div class="stat-card-number">4.8★</div>
                                        <div class="stat-card-label">Average Rating</div>
                                    </div>
                                </div>
                            </div>
                        </section>

                        <!-- FEATURED COURSES SECTION -->
                        <section class="py-5" style="background: var(--bg-light);">
                            <div class="container">
                                <h2 class="section-title">Featured Courses</h2>
                                <p class="section-subtitle">Start your learning journey with our most popular courses</p>
                                <div class="row g-4">
                                    <t t-foreach="courses" t-as="course">
                                        <div class="col-lg-4 col-md-6">
                                            <div class="course-card">
                                                <div class="course-card-image">
                                                    <span class="course-card-badge" t-text="course.category_id.name or 'General'"/>
                                                </div>
                                                <div class="course-card-body">
                                                    <h5 class="course-card-title" t-text="course.name"/>
                                                    <span class="course-card-category" t-text="(course.difficulty or 'Beginner').title()"/>
                                                    <div class="course-card-rating">
                                                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                                                        <span class="ms-2">4.8 (242 reviews)</span>
                                                    </div>
                                                    <p class="mt-3" style="color: var(--text-light); font-size: 0.9rem;" t-text="(course.description or 'Learn valuable skills')[:100] + '...'"/>
                                                </div>
                                                <div class="course-card-footer">
                                                    <span class="course-card-price">Free</span>
                                                    <a href="/impc/courses" class="btn btn-primary">View Course</a>
                                                </div>
                                            </div>
                                        </div>
                                    </t>
                                </div>
                                <div class="text-center mt-5">
                                    <a href="/impc/courses" class="btn btn-primary btn-lg">View All Courses</a>
                                </div>
                            </div>
                        </section>

                        <!-- LEARNING MODES SECTION -->
                        <section class="py-5" id="features">
                            <div class="container">
                                <h2 class="section-title">How It Works</h2>
                                <p class="section-subtitle">Choose the learning path that works best for you</p>
                                <div class="row g-4">
                                    <div class="col-lg-4">
                                        <div class="feature-card">
                                            <div class="feature-icon">📚</div>
                                            <h5>Self-Paced Learning</h5>
                                            <p>Learn at your own speed, complete courses whenever you want</p>
                                            <ul class="feature-list">
                                                <li>Video lessons</li>
                                                <li>Downloadable materials</li>
                                                <li>Lifetime access</li>
                                            </ul>
                                        </div>
                                    </div>
                                    <div class="col-lg-4">
                                        <div class="feature-card">
                                            <div class="feature-icon">🏆</div>
                                            <h5>Industry Certifications</h5>
                                            <p>Earn recognized credentials that boost your career</p>
                                            <ul class="feature-list">
                                                <li>Verified certificates</li>
                                                <li>Shareable credentials</li>
                                                <li>LinkedIn integration</li>
                                            </ul>
                                        </div>
                                    </div>
                                    <div class="col-lg-4">
                                        <div class="feature-card">
                                            <div class="feature-icon">👨‍🏫</div>
                                            <h5>Expert Instructors</h5>
                                            <p>Learn from industry professionals and experts</p>
                                            <ul class="feature-list">
                                                <li>Real-world experience</li>
                                                <li>Q&amp;A support</li>
                                                <li>Best practices</li>
                                            </ul>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </section>

                        <!-- CTA SECTION -->
                        <section class="py-5" style="background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%); color: white;">
                            <div class="container text-center">
                                <h2 style="color: white; margin-bottom: 1rem;">Ready to Get Started?</h2>
                                <p style="font-size: 1.1rem; margin-bottom: 2rem; opacity: 0.9;">Join thousands of learners advancing their careers</p>
                                <a href="/impc/courses" class="btn btn-outline-light btn-lg">Browse All Courses</a>
                            </div>
                        </section>
                    </main>
                </div>
            </t>
        </template>
    </data>
</odoo>
