<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!-- ============================
         Skill Mapping Log - List View
    ============================ -->
    <record id="hr_skill_mapping_log_view_list" model="ir.ui.view">
        <field name="name">hr.skill.mapping.log.list</field>
        <field name="model">hr.skill.mapping.log</field>
        <field name="arch" type="xml">
            <list string="Skill Mapping Audit Log" create="0" edit="0">
                <field name="employee_id"/>
                <field name="skill_id"/>
                <field name="course_name"/>
                <field name="skill_level_before"/>
                <field name="skill_level_after"/>
                <field name="change_date"/>
                <field name="certificate_id"/>
            </list>
        </field>
    </record>

    <!-- ============================
         Skill Mapping Log - Action
    ============================ -->
    <record id="hr_skill_mapping_log_action" model="ir.actions.act_window">
        <field name="name">Skill Mapping Audit Log</field>
        <field name="res_model">hr.skill.mapping.log</field>
        <field name="view_mode">list</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No skill changes recorded yet
            </p>
            <p>
                This log tracks all automatic skill updates triggered by
                certificate issuance from the eLearning platform.
            </p>
        </field>
    </record>
</odoo>
