<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!-- ============================
         Learning Progress - List View (Dashboard)
    ============================ -->
    <record id="hr_learning_progress_view_list" model="ir.ui.view">
        <field name="name">hr.learning.progress.list</field>
        <field name="model">hr.learning.progress</field>
        <field name="arch" type="xml">
            <list string="Learning Progress Dashboard"
                  decoration-danger="status == 'AT_RISK'"
                  decoration-success="status == 'COMPLETED'"
                  export_xlsx="1">
                <field name="employee_id"/>
                <field name="department_id"/>
                <field name="course_name"/>
                <field name="learning_mode" widget="badge"
                       decoration-info="learning_mode == 'ONLINE'"
                       decoration-warning="learning_mode == 'HYBRID'"
                       decoration-success="learning_mode == 'OFFLINE'"/>
                <field name="enrollment_date"/>
                <field name="completion_percentage" widget="progressbar"/>
                <field name="attendance_status" widget="badge"
                       decoration-success="attendance_status == 'HADIR'"
                       decoration-danger="attendance_status == 'TIDAK_HADIR'"
                       decoration-warning="attendance_status == 'PENDING'"
                       invisible="learning_mode != 'HYBRID'"/>
                <field name="checkin_time" invisible="learning_mode != 'HYBRID'"/>
                <field name="quiz_score"/>
                <field name="status" widget="badge"
                       decoration-info="status == 'IN_PROGRESS'"
                       decoration-success="status == 'COMPLETED'"
                       decoration-danger="status == 'AT_RISK'"/>
                <field name="last_accessed_date"/>
                <field name="synced_at" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- ============================
         Learning Progress - Form View
    ============================ -->
    <record id="hr_learning_progress_view_form" model="ir.ui.view">
        <field name="name">hr.learning.progress.form</field>
        <field name="model">hr.learning.progress</field>
        <field name="arch" type="xml">
            <form string="Learning Progress Detail" create="0" edit="0">
                <header>
                    <field name="status" widget="statusbar"
                           statusbar_visible="IN_PROGRESS,COMPLETED"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="employee_id" readonly="1"/>
                        </h1>
                        <h2>
                            <field name="course_name" readonly="1"/>
                        </h2>
                    </div>
                    <group>
                        <group string="Course Information">
                            <field name="course_id"/>
                            <field name="course_name"/>
                            <field name="learning_mode"/>
                            <field name="enrollment_id"/>
                            <field name="enrollment_date"/>
                        </group>
                        <group string="Progress">
                            <field name="completion_percentage" widget="progressbar"/>
                            <field name="quiz_score"/>
                            <field name="last_accessed_date"/>
                            <field name="estimated_completion_date"/>
                        </group>
                    </group>
                    <group string="Hybrid Attendance"
                           invisible="learning_mode != 'HYBRID'">
                        <field name="attendance_status"/>
                        <field name="checkin_time"/>
                    </group>
                    <group string="Sync Info">
                        <field name="synced_at"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ============================
         Learning Progress - Search View
    ============================ -->
    <record id="hr_learning_progress_view_search" model="ir.ui.view">
        <field name="name">hr.learning.progress.search</field>
        <field name="model">hr.learning.progress</field>
        <field name="arch" type="xml">
            <search string="Search Learning Progress">
                <field name="employee_id"/>
                <field name="course_name"/>
                <field name="department_id"/>
                <separator/>
                <filter name="filter_in_progress" string="In Progress"
                        domain="[('status', '=', 'IN_PROGRESS')]"/>
                <filter name="filter_completed" string="Completed"
                        domain="[('status', '=', 'COMPLETED')]"/>
                <filter name="filter_at_risk" string="At Risk"
                        domain="[('status', '=', 'AT_RISK')]"/>
                <separator/>
                <filter name="filter_hybrid" string="Hybrid Courses"
                        domain="[('learning_mode', '=', 'HYBRID')]"/>
                <filter name="filter_online" string="Online Courses"
                        domain="[('learning_mode', '=', 'ONLINE')]"/>
                <separator/>
                <filter name="filter_attendance_pending" string="Attendance Pending"
                        domain="[('attendance_status', '=', 'PENDING')]"/>
                <filter name="filter_attendance_hadir" string="Hadir"
                        domain="[('attendance_status', '=', 'HADIR')]"/>
                <filter name="filter_attendance_tidak_hadir" string="Tidak Hadir"
                        domain="[('attendance_status', '=', 'TIDAK_HADIR')]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter name="group_department" string="Department"
                            context="{'group_by': 'department_id'}"/>
                    <filter name="group_status" string="Status"
                            context="{'group_by': 'status'}"/>
                    <filter name="group_learning_mode" string="Learning Mode"
                            context="{'group_by': 'learning_mode'}"/>
                    <filter name="group_course" string="Course"
                            context="{'group_by': 'course_name'}"/>
                    <filter name="group_attendance" string="Attendance"
                            context="{'group_by': 'attendance_status'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ============================
         Learning Progress - Pivot View
    ============================ -->
    <record id="hr_learning_progress_view_pivot" model="ir.ui.view">
        <field name="name">hr.learning.progress.pivot</field>
        <field name="model">hr.learning.progress</field>
        <field name="arch" type="xml">
            <pivot string="Learning Progress Analysis">
                <field name="department_id" type="row"/>
                <field name="status" type="col"/>
                <field name="completion_percentage" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- ============================
         Learning Progress - Graph View
    ============================ -->
    <record id="hr_learning_progress_view_graph" model="ir.ui.view">
        <field name="name">hr.learning.progress.graph</field>
        <field name="model">hr.learning.progress</field>
        <field name="arch" type="xml">
            <graph string="Learning Progress" type="bar">
                <field name="department_id"/>
                <field name="completion_percentage" type="measure"/>
            </graph>
        </field>
    </record>

    <!-- ============================
         Learning Progress - Action
    ============================ -->
    <record id="hr_learning_progress_action" model="ir.actions.act_window">
        <field name="name">Learning Progress Dashboard</field>
        <field name="res_model">hr.learning.progress</field>
        <field name="view_mode">list,form,pivot,graph</field>
        <field name="search_view_id" ref="hr_learning_progress_view_search"/>
        <field name="context">{'search_default_filter_in_progress': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No learning progress data yet
            </p>
            <p>
                Learning progress data is automatically synced from the eLearning
                platform every 5 minutes. Once employees are enrolled in courses,
                their progress will appear here.
            </p>
        </field>
    </record>

    <!-- Action: At-Risk Employees (filtered) -->
    <record id="hr_learning_progress_at_risk_action" model="ir.actions.act_window">
        <field name="name">At-Risk Employees</field>
        <field name="res_model">hr.learning.progress</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="hr_learning_progress_view_search"/>
        <field name="domain">[('status', '=', 'AT_RISK')]</field>
    </record>

</odoo>
