<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!-- ============================
         Learning Progress - List View (Dashboard)
    ============================ -->
    <record id="hr_learning_progress_view_list" model="ir.ui.view">
        <field name="name">hr.learning.progress.list</field>
        <field name="model">hr.learning.progress</field>
        <field name="arch" type="xml">
            <list string="Learning Progress Dashboard"
                  decoration-danger="status == 'AT_RISK'"
                  decoration-success="status == 'COMPLETED'">
                <field name="employee_id"/>
                <field name="department_id"/>
                <field name="course_name"/>
                <field name="learning_mode"/>
                <field name="enrollment_date"/>
                <field name="completion_percentage"/>
                <field name="attendance_status" optional="show"/>
                <field name="checkin_time" optional="hide"/>
                <field name="quiz_score"/>
                <field name="status"/>
                <field name="last_accessed_date"/>
                <field name="synced_at" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- ============================
         Learning Progress - Form View
    ============================ -->
    <record id="hr_learning_progress_view_form" model="ir.ui.view">
        <field name="name">hr.learning.progress.form</field>
        <field name="model">hr.learning.progress</field>
        <field name="arch" type="xml">
            <form string="Learning Progress Detail">
                <sheet>
                    <group>
                        <group string="Employee">
                            <field name="employee_id" readonly="1"/>
                            <field name="department_id" readonly="1"/>
                        </group>
                        <group string="Course Information">
                            <field name="course_id" readonly="1"/>
                            <field name="course_name" readonly="1"/>
                            <field name="learning_mode" readonly="1"/>
                            <field name="enrollment_date" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <group string="Progress">
                            <field name="completion_percentage" readonly="1"/>
                            <field name="quiz_score" readonly="1"/>
                            <field name="status" readonly="1"/>
                            <field name="last_accessed_date" readonly="1"/>
                            <field name="estimated_completion_date" readonly="1"/>
                        </group>
                        <group string="Attendance (Hybrid)">
                            <field name="attendance_status" readonly="1"/>
                            <field name="checkin_time" readonly="1"/>
                        </group>
                    </group>
                    <group string="Sync Info">
                        <field name="synced_at" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ============================
         Learning Progress - Search View
    ============================ -->
    <record id="hr_learning_progress_view_search" model="ir.ui.view">
        <field name="name">hr.learning.progress.search</field>
        <field name="model">hr.learning.progress</field>
        <field name="arch" type="xml">
            <search string="Search Learning Progress">
                <field name="employee_id"/>
                <field name="course_name"/>
                <field name="department_id"/>
                <separator/>
                <filter name="filter_in_progress" string="In Progress"
                        domain="[('status', '=', 'IN_PROGRESS')]"/>
                <filter name="filter_completed" string="Completed"
                        domain="[('status', '=', 'COMPLETED')]"/>
                <filter name="filter_at_risk" string="At Risk"
                        domain="[('status', '=', 'AT_RISK')]"/>
                <separator/>
                <filter name="filter_hybrid" string="Hybrid Courses"
                        domain="[('learning_mode', '=', 'HYBRID')]"/>
                <filter string="Department" name="group_department" domain="[]" context="{'group_by': 'department_id'}"/>
                <filter string="Status" name="group_status" domain="[]" context="{'group_by': 'status'}"/>
                <filter string="Learning Mode" name="group_learning_mode" domain="[]" context="{'group_by': 'learning_mode'}"/>
            </search>
        </field>
    </record>

    <!-- ============================
         Learning Progress - Graph View
    ============================ -->
    <record id="hr_learning_progress_view_graph" model="ir.ui.view">
        <field name="name">hr.learning.progress.graph</field>
        <field name="model">hr.learning.progress</field>
        <field name="arch" type="xml">
            <graph string="Learning Progress" type="bar">
                <field name="department_id"/>
                <field name="completion_percentage" type="measure"/>
            </graph>
        </field>
    </record>

    <!-- ============================
         Learning Progress - Action
    ============================ -->
    <record id="hr_learning_progress_action" model="ir.actions.act_window">
        <field name="name">Learning Progress Dashboard</field>
        <field name="res_model">hr.learning.progress</field>
        <field name="view_mode">list,form,graph</field>
        <field name="search_view_id" ref="hr_learning_progress_view_search"/>
        <field name="context">{'search_default_filter_in_progress': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No learning progress data yet
            </p>
            <p>
                Learning progress data is automatically synced from the eLearning
                platform every 5 minutes.
            </p>
        </field>
    </record>

    <!-- Action: At-Risk Employees (filtered) -->
    <record id="hr_learning_progress_at_risk_action" model="ir.actions.act_window">
        <field name="name">At-Risk Employees</field>
        <field name="res_model">hr.learning.progress</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="hr_learning_progress_view_search"/>
        <field name="domain">[('status', '=', 'AT_RISK')]</field>
    </record>

</odoo>
