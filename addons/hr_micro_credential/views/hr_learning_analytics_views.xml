<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!-- ============================
         Learning Analytics Snapshot - List View
    ============================ -->
    <record id="hr_learning_analytics_view_list" model="ir.ui.view">
        <field name="name">hr.learning.analytics.snapshot.list</field>
        <field name="model">hr.learning.analytics.snapshot</field>
        <field name="arch" type="xml">
            <list string="Learning Analytics">
                <field name="department_id"/>
                <field name="snapshot_date"/>
                <field name="total_employees_in_learning"/>
                <field name="avg_completion_percentage" widget="progressbar"/>
                <field name="total_certificates_this_period"/>
                <field name="completion_rate"/>
                <field name="at_risk_count"
                       decoration-danger="at_risk_count > 0"/>
            </list>
        </field>
    </record>

    <!-- ============================
         Learning Analytics Snapshot - Pivot View
    ============================ -->
    <record id="hr_learning_analytics_view_pivot" model="ir.ui.view">
        <field name="name">hr.learning.analytics.snapshot.pivot</field>
        <field name="model">hr.learning.analytics.snapshot</field>
        <field name="arch" type="xml">
            <pivot string="Learning Analytics">
                <field name="department_id" type="row"/>
                <field name="snapshot_date" type="col" interval="month"/>
                <field name="avg_completion_percentage" type="measure"/>
                <field name="total_certificates_this_period" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- ============================
         Learning Analytics Snapshot - Graph View
    ============================ -->
    <record id="hr_learning_analytics_view_graph" model="ir.ui.view">
        <field name="name">hr.learning.analytics.snapshot.graph</field>
        <field name="model">hr.learning.analytics.snapshot</field>
        <field name="arch" type="xml">
            <graph string="Learning Analytics" type="line">
                <field name="snapshot_date" interval="week"/>
                <field name="avg_completion_percentage" type="measure"/>
            </graph>
        </field>
    </record>

    <!-- ============================
         Learning Analytics - Search View
    ============================ -->
    <record id="hr_learning_analytics_view_search" model="ir.ui.view">
        <field name="name">hr.learning.analytics.snapshot.search</field>
        <field name="model">hr.learning.analytics.snapshot</field>
        <field name="arch" type="xml">
            <search string="Search Analytics">
                <field name="department_id"/>
                <field name="snapshot_date"/>
                <group expand="0" string="Group By">
                    <filter name="group_department" string="Department"
                            context="{'group_by': 'department_id'}"/>
                    <filter name="group_month" string="Month"
                            context="{'group_by': 'snapshot_date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ============================
         Learning Analytics - Action
    ============================ -->
    <record id="hr_learning_analytics_action" model="ir.actions.act_window">
        <field name="name">Learning Analytics</field>
        <field name="res_model">hr.learning.analytics.snapshot</field>
        <field name="view_mode">graph,pivot,list</field>
        <field name="search_view_id" ref="hr_learning_analytics_view_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No analytics data yet
            </p>
            <p>
                Analytics snapshots are generated daily. Once learning progress
                data is available, analytics will be computed automatically.
            </p>
        </field>
    </record>
</odoo>
