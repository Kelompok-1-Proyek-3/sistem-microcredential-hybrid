<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!-- ============================
         Security Groups
    ============================ -->

    <record id="group_hr_micro_credential_user" model="res.groups">
        <field name="name">HR Microcredential User</field>
        <field name="category_id" ref="base.module_category_human_resources_employees"/>
        <field name="implied_ids" eval="[(4, ref('hr.group_hr_user'))]"/>
        <field name="comment">
            Can view learning progress dashboards, employee learning profiles,
            and analytics. Read-only access to eLearning synced data.
        </field>
    </record>

    <record id="group_hr_micro_credential_manager" model="res.groups">
        <field name="name">HR Microcredential Manager</field>
        <field name="category_id" ref="base.module_category_human_resources_employees"/>
        <field name="implied_ids" eval="[(4, ref('group_hr_micro_credential_user'))]"/>
        <field name="comment">
            Full access to HR Microcredential features: manage skill mappings,
            configure at-risk thresholds, send alerts, manage analytics.
        </field>
    </record>

    <!-- ============================
         Record Rules
    ============================ -->

    <!-- Learning Progress: HR user can only see employees in their department -->
    <record id="hr_learning_progress_rule_user" model="ir.rule">
        <field name="name">Learning Progress: Department-based access</field>
        <field name="model_id" ref="model_hr_learning_progress"/>
        <field name="domain_force">[
            '|',
            ('employee_id.department_id.manager_id.user_id', '=', user.id),
            ('employee_id.department_id', 'in', user.employee_ids.department_id.ids),
        ]</field>
        <field name="groups" eval="[(4, ref('group_hr_micro_credential_user'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- Learning Progress: Manager has full read access -->
    <record id="hr_learning_progress_rule_manager" model="ir.rule">
        <field name="name">Learning Progress: Manager full read access</field>
        <field name="model_id" ref="model_hr_learning_progress"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_hr_micro_credential_manager'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <!-- Profile Notes: only HR users can see notes -->
    <record id="hr_learning_profile_note_rule" model="ir.rule">
        <field name="name">Learning Notes: HR only</field>
        <field name="model_id" ref="model_hr_learning_profile_note"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_hr_micro_credential_user'))]"/>
    </record>

</odoo>
