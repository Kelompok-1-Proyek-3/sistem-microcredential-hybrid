<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!-- ============================
         Email Template: At-Risk Employee Alert
    ============================ -->
    <record id="mail_template_at_risk_alert" model="mail.template">
        <field name="name">HR Microcredential: At-Risk Learning Alert</field>
        <field name="model_id" ref="model_hr_learning_progress"/>
        <field name="subject">🚨 At-Risk Learning Alert: {{ object.employee_id.name }}</field>
        <field name="email_from">{{ (object.employee_id.company_id.email or user.email) }}</field>
        <field name="email_to">{{ (object.employee_id.parent_id.work_email or '') }}</field>
        <field name="body_html"><![CDATA[
<div style="margin: 0px; padding: 0px;">
    <p>Hi <t t-out="object.employee_id.parent_id.name or 'HR Manager'"/>,</p>
    
    <p><strong><t t-out="object.employee_id.name"/></strong> appears to be at risk in their course:</p>
    
    <table style="border-collapse: collapse; width: 100%; margin: 10px 0;">
        <tr>
            <td style="padding: 8px; border: 1px solid #ddd;"><strong>Course</strong></td>
            <td style="padding: 8px; border: 1px solid #ddd;"><t t-out="object.course_name"/></td>
        </tr>
        <tr>
            <td style="padding: 8px; border: 1px solid #ddd;"><strong>Status</strong></td>
            <td style="padding: 8px; border: 1px solid #ddd; color: #d9534f;"><t t-out="object.status"/></td>
        </tr>
        <tr>
            <td style="padding: 8px; border: 1px solid #ddd;"><strong>Current Progress</strong></td>
            <td style="padding: 8px; border: 1px solid #ddd;"><t t-out="object.completion_percentage"/>%</td>
        </tr>
        <tr>
            <td style="padding: 8px; border: 1px solid #ddd;"><strong>Last Activity</strong></td>
            <td style="padding: 8px; border: 1px solid #ddd;"><t t-out="object.last_accessed_date or 'N/A'"/></td>
        </tr>
        <tr t-if="object.learning_mode == 'HYBRID'">
            <td style="padding: 8px; border: 1px solid #ddd;"><strong>Attendance Status</strong></td>
            <td style="padding: 8px; border: 1px solid #ddd;"><t t-out="object.attendance_status"/></td>
        </tr>
    </table>
    
    <p><strong>Recommended Action:</strong> Reach out to discuss barriers &amp; provide support.</p>
    
    <p>Best regards,<br/>IMPC Learning System</p>
</div>
        ]]></field>
        <field name="auto_delete" eval="True"/>
    </record>
</odoo>
