<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Server Action untuk Cron: Flag kontrak mendekati expiry -->
        <record id="action_server_cron_flag_renewal" model="ir.actions.server">
            <field name="name">Sales: Flag Kontrak yang Akan Expired</field>
            <field name="model_id" ref="sale.model_sale_order"/>
            <field name="state">code</field>
            <field name="code">model._cron_flag_renewal_contracts()</field>
        </record>

        <!-- Cron: jalankan tiap hari (Odoo 19: ir.cron link ke ir.actions.server) -->
        <record id="ir_cron_flag_renewal_contracts" model="ir.cron">
            <field name="ir_actions_server_id" ref="action_server_cron_flag_renewal"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>
