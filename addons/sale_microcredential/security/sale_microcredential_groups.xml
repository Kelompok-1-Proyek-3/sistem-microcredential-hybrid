<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        Security Groups — sale_microcredential
        DEV 1 scope: group definition only.

        HIERARCHY (dari tinggi ke rendah):
          base.group_user  (Employee / Internal User)
            └── sales_team.group_sale_salesman
                  └── sale_microcredential.group_sales_microcredential_manager
          base.group_portal
            └── (flag: is_hr_partner_admin = True  → bukan group, cukup boolean field)

        Catatan:
          - group_hr_partner   : Grup untuk user portal perwakilan HR mitra B2B.
                                 Diberi akses READ-ONLY pada sale.order & sale.order.line.
          - group_sales_..._manager : Sales Manager IMPC, dapat melakukan semua aksi kontrak B2B.
    -->

    <!-- 1. Group: HR Partner (portal user mitra B2B) -->
    <record id="group_hr_partner" model="res.groups">
        <field name="name">Sales Microcredential / HR Partner</field>
        <field name="category_id" ref="base.module_category_hidden"/>
        <field name="comment">
            User portal dari perusahaan mitra B2B yang diberikan akses
            read-only untuk melihat kontrak dan redeem code milik perusahaannya.
        </field>
    </record>

    <!-- 2. Group: Sales Microcredential Manager -->
    <record id="group_sales_microcredential_manager" model="res.groups">
        <field name="name">Sales Microcredential / Manager</field>
        <field name="category_id" ref="base.module_category_hidden"/>
        <field name="implied_ids" eval="[(4, ref('sales_team.group_sale_manager'))]"/>
        <field name="comment">
            Sales Manager internal IMPC. Dapat melihat semua kontrak B2B,
            generate redeem code, kirim email, dan kelola renewal.
        </field>
    </record>

</odoo>
