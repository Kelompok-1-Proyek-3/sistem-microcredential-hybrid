<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        Security Groups — sale_microcredential

        HIERARCHY (dari tinggi ke rendah):
          base.group_user  (Employee / Internal User)
            └── sales_team.group_sale_salesman
                  └── sale_microcredential.group_sales_microcredential_manager
          base.group_portal
            └── sale_microcredential.group_hr_partner
                  (flag: is_hr_partner_admin = True  → bukan group, cukup boolean field)

        Catatan:
          - group_hr_partner   : Grup untuk user portal perwakilan HR mitra B2B.
                                 Diberi akses READ-ONLY pada sale.order, sale.order.line,
                                 impc.redeem.code.batch, dan impc.redeem.code.
          - group_sales_..._manager : Sales Manager IMPC, dapat melakukan semua aksi kontrak B2B.
    -->

    <!-- 1. Group: HR Partner (portal user mitra B2B) -->
    <record id="group_hr_partner" model="res.groups">
        <field name="name">Sales Microcredential / HR Partner</field>
        <field name="implied_ids" eval="[(4, ref('base.group_portal'))]"/>
        <field name="comment">Portal group for B2B HR partners. Grants read-only access to contracts and redeem codes belonging to their company.</field>
    </record>

    <!-- 2. Group: Sales Microcredential Manager -->
    <record id="group_sales_microcredential_manager" model="res.groups">
        <field name="name">Sales Microcredential / Manager</field>
        <field name="implied_ids" eval="[(4, ref('sales_team.group_sale_manager'))]"/>
    </record>

    <!-- ============================================================ -->
    <!-- Record Rules: HR Partner access scoped to own company data   -->
    <!-- ============================================================ -->

    <!-- HR Partner can read sale.order belonging to their commercial partner -->
    <record id="rule_hr_partner_sale_order" model="ir.rule">
        <field name="name">Sale Order: HR Partner sees own company contracts</field>
        <field name="model_id" ref="sale.model_sale_order"/>
        <field name="domain_force">[
            ('partner_id.commercial_partner_id', '=', user.partner_id.commercial_partner_id.id),
            ('contract_type', '=', 'B2B_CONTRACT'),
        ]</field>
        <field name="groups" eval="[(4, ref('sale_microcredential.group_hr_partner'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- HR Partner can read impc.redeem.code.batch belonging to their company -->
    <record id="rule_hr_partner_redeem_batch" model="ir.rule">
        <field name="name">Redeem Code Batch: HR Partner sees own company batches</field>
        <field name="model_id" ref="impc_website.model_impc_redeem_code_batch"/>
        <field name="domain_force">[
            ('partner_id.commercial_partner_id', '=', user.partner_id.commercial_partner_id.id),
        ]</field>
        <field name="groups" eval="[(4, ref('sale_microcredential.group_hr_partner'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- HR Partner can read impc.redeem.code from their company's batches -->
    <record id="rule_hr_partner_redeem_code" model="ir.rule">
        <field name="name">Redeem Code: HR Partner sees own company codes</field>
        <field name="model_id" ref="impc_website.model_impc_redeem_code"/>
        <field name="domain_force">[
            ('batch_id.partner_id.commercial_partner_id', '=', user.partner_id.commercial_partner_id.id),
        ]</field>
        <field name="groups" eval="[(4, ref('sale_microcredential.group_hr_partner'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

</odoo>
