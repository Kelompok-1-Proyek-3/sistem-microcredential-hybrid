<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_marketing_event_conversion_tree" model="ir.ui.view">
        <field name="name">marketing.event.conversion.report.tree</field>
        <field name="model">marketing.event.conversion.report</field>
        <field name="arch" type="xml">
            <list string="Weekly Event Conversion">
                <field name="event_id"/>
                <field name="course_id"/>
                <field name="week_start"/>
                <field name="week_end"/>
                <field name="registered_count"/>
                <field name="attended_count"/>
                <field name="enrolled_count"/>
                <field name="conversion_rate"/>
            </list>
        </field>
    </record>

    <record id="view_marketing_event_conversion_form" model="ir.ui.view">
        <field name="name">marketing.event.conversion.report.form</field>
        <field name="model">marketing.event.conversion.report</field>
        <field name="arch" type="xml">
            <form string="Weekly Event Conversion">
                <sheet>
                    <group>
                        <field name="event_id"/>
                        <field name="course_id"/>
                        <field name="week_start"/>
                        <field name="week_end"/>
                        <field name="registered_count"/>
                        <field name="attended_count"/>
                        <field name="enrolled_count"/>
                        <field name="conversion_rate"/>
                        <field name="last_synced"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_marketing_event_conversion_report" model="ir.actions.act_window">
        <field name="name">Weekly Event Conversion</field>
        <field name="res_model">marketing.event.conversion.report</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
