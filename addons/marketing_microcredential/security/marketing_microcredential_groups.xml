<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="group_marketing_microcredential_report_manager" model="res.groups">
            <field name="name">IMPC Marketing Reports Manager</field>
            <field name="implied_ids" eval="[
                (4, ref('event.group_event_manager')),
                (4, ref('survey.group_survey_manager')),
                (4, ref('mail.group_mail_canned_response_admin')),
            ]"/>
        </record>
        <!-- Administrator auto-access: base.group_system implies marketing group -->
        <record id="base.group_system" model="res.groups">
            <field name="implied_ids" eval="[
                (4, ref('marketing_microcredential.group_marketing_microcredential_report_manager')),
            ]"/>
        </record>
    </data>
</odoo>
